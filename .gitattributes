# Prevent .env files from being committed
.env filter=git-crypt diff=git-crypt
.env.local filter=git-crypt diff=git-crypt
.env.*.local filter=git-crypt diff=git-crypt

# Line endings
* text=auto
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
