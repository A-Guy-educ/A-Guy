"episodeId":"ep_stage_diary_002","source":"stage_diary","content":"{\"stage\":\"review-fix\",\"insights\":[{\"kind\":\"decision\",\"text\":\"Adding a clarifying comment is a valid fix when the behavior is correct by design but not self-explanatory to future readers.\",\"scope\":\"code review\"},{\"kind\":\"gotcha\",\"text\":\"AdvancedContentEditor is an exercise-editor role, not a course-manager role — intentionally excluded from instructor list read access.\",\"scope\":\"LMS/permissions\"},{\"kind\":\"lesson\",\"text\":\"When fixing review feedback, prefer the minimal appropriate solution rather than over-engineering.\",\"scope\":\"PR workflow\"}]}","createdAt":"2026-04-17T21:21:41.525Z","wordCount":548,"positions":[2,10,17,23,36,43,54,61,70,81,94,100,113,125,136,147,151,156,171,178,189,197,202,213,220,229,236,264,273,280,286,292,299,307,314,328,342,353,358,363,373,381,385,401,408,417,429,436,443,453,464,472,484,493,500,505,510,525,533,536]}},"totalDocs":2}