{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_waua5o3elmjm_1","type":"tool_result","content":"1\t/**\n2\t * GET /api/lessons/:id/export\n3\t *\n4\t * Exports a lesson and all its ordered exercises as a JSON file.\n5\t *\n6\t * Access: admin only (401 unauthenticated, 403 non-admin).\n7\t *\n8\t * Response: Content-Type: application/json, Content-Disposition: attachment; filename=\"<slug>.json\"\n9\t *\n10\t * JSON shape:\n11\t * {\n12\t *   lesson: { id, title, slug, description, type, status, order, accessType, visibleRenderers, ... },\n13\t *   exercises: [ { id, title, slug, content, origin, ... }, ... ],  // ordered by blocks array\n14\t *   meta: {\n15\t *     exerciseCount: number,\n16\t *     missingExerciseRefs: string[],      // IDs in blocks but not in DB\n17\t *     skippedNonExerciseBlocks: number,  // contentPageRef etc.\n18\t *   }\n19\t * }\n20\t *\n21\t * Excluded from exercise payload: createdAt, updatedAt, internal _id, __v\n22\t *\n23\t * @fileType api-route\n24\t * @domain lessons\n25\t * @pattern lesson-export\n26\t * @ai-summary Exports a lesson and its ordered exercises as a JSON file for backup or offline review.\n27\t */\n28\timport type { PayloadRequest } from 'payload'\n29\t\n30\ttype BlockEntry = { id: string; blockType: string; exercise?: string; contentPage?: string }\n31\t\n32\t/**\n33\t * Strip Payload-managed timestamp fields from a doc. The `id` is preserved —\n34\t * it's data (not a server-managed timestamp), and downstream consumers need\n35\t * it to round-trip the export back into the system. The endpoint's documented\n36\t * JSON shape and its integration test both require `id` to be present.\n37\t */\n38\tfunction stripManagedFields<T extends Record<string, unknown>>(\n39\t  doc: T,\n40\t): Omit<T, 'createdAt' | 'updatedAt'> {\n41\t  const {\n42\t    createdAt: _c,\n43\t    updatedAt: _u,\n44\t    ...rest\n45\t  } = doc as T & {\n46\t    createdAt?: unknown\n47\t    updatedAt?: unknown\n48\t  }\n49\t  void _c\n50\t  void _u\n51\t  return rest\n52\t}\n53\t\n54\t/** Parse blocks from JSON string or array */\n55\tfunction parseBlocks(raw: unknown): BlockEntry[] {\n56\t  if (Array.isArray(raw)) return raw as BlockEntry[]\n57\t  if (typeof raw === 'string' && raw.trim()) {\n58\t    try {\n59\t      const parsed = JSON.parse(raw)\n60\t      if (Array.isArray(parsed)) return parsed as BlockEntry[]\n61\t    } catch {\n62\t      // ignore parse errors\n63\t    }\n64\t  }\n65\t  return []\n66\t}\n67\t\n68\texport async function exportLessonEndpoint(req: PayloadRequest): Promise<Response> {\n69\t  // 1) Auth — admin only\n70\t  const user = req.user\n71\t  if (!user) {\n72\t    return Response.json({ error: 'Authentication required' }, { status: 401 })\n73\t  }\n74\t  if (!('role' in user) || user.role !== 'admin') {\n75\t    return Response.json({ error: 'Admin access required' }, { status: 403 })\n76\t  }\n77\t\n78\t  // 2) Extract lesson ID from path: /lessons/:id/export\n79\t  const url = new URL(req.url || 'http://localhost')\n80\t  const match = url.pathname.match(/\\/lessons\\/([^/]+)\\/export/)\n81\t  const lessonId = match?.[1]\n82\t  if (!lessonId) {\n83\t    return Response.json({ error: 'Lesson id missing from path' }, { status: 400 })\n84\t  }\n85\t\n86\t  // 3) Fetch lesson with depth:0\n87\t  let lesson: Record<string, unknown>\n88\t  try {\n89\t    lesson = (await req.payload.findByID({\n90\t      collection: 'lessons',\n91\t      id: lessonId,\n92\t      depth: 0,\n93\t      overrideAccess: true,\n94\t      req,\n95\t    })) as unknown as Record<string, unknown>\n96\t  } catch {\n97\t    return Response.json({ error: 'Lesson not found' }, { status: 404 })\n98\t  }\n99\t\n100\t  // 4) Parse blocks, extract ordered exercise IDs (exerciseRef only)\n101\t  const blocks = parseBlocks(lesson.blocks)\n102\t  const exerciseIds: string[] = []\n103\t  let skippedNonExerciseBlocks = 0\n104\t  const missingIds: string[] = []\n105\t\n106\t  for (const block of blocks) {\n107\t    if (block.blockType === 'exerciseRef' && block.exercise) {\n108\t      exerciseIds.push(block.exercise)\n109\t    } else {\n110\t      skippedNonExerciseBlocks++\n111\t    }\n112\t  }\n113\t\n114\t  // 5) Fetch exercises in order, track missing ones\n115\t  const exercises: unknown[] = []\n116\t  for (const exId of exerciseIds) {\n117\t    try {\n118\t      const ex = (await req.payload.findByID({\n119\t        collection: 'exercises',\n120\t        id: exId,\n121\t        depth: 0,\n122\t        overrideAccess: true,\n123\t        req,\n124\t      })) as unknown as Record<string, unknown>\n125\t      exercises.push(stripManagedFields(ex))\n126\t    } catch {\n127\t      missingIds.push(exId)\n128\t    }\n129\t  }\n130\t\n131\t<<<<<<< HEAD\n132\t  // 6) Build response — strip managed fields from lesson\n133\t=======\n134\t  // 6) Build response — strip managed timestamps + raw blocks (the lesson's\n135\t  // `blocks` field is a serialized JSON string for storage; we expose the\n136\t  // ordered exercises array via `exercises` instead). `id` is preserved.\n137\t>>>>>>> origin/dev\n138\t  const { createdAt: _lca, updatedAt: _lua, blocks: _lb, ...lessonData } = lesson\n139\t  void _lca\n140\t  void _lua\n141\t  void _lb\n142\t\n143\t  const responseBody = {\n144\t    lesson: { ...lessonData, id: lessonId },\n145\t    exercises,\n146\t    meta: {\n147\t      exerciseCount: exercises.length,\n148\t      missingExerciseRefs: missingIds,\n149\t      skippedNonExerciseBlocks,\n150\t    },\n151\t  }\n152\t\n153\t  const slug = (lesson.slug as string) || lessonId\n154\t  const filename = `${slug}.json`\n155\t\n156\t  return new Response(JSON.stringify(responseBody, null, 2), {\n157\t    headers: {\n158\t      'Content-Type': 'application/json',\n159\t      'Content-Disposition': `attachment; filename=\"${filename}\"`,\n160\t    },\n161\t  })\n162\t}\n163\t"}]},"parent_tool_use_id":null,"session_id":"9481d071-e7a4-45b7-8d94-1b982f197060","uuid":"afe6b2f9