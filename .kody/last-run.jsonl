{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_gn63hteklosm_1","type":"tool_result","content":"1\t/**\n2\t * Integration test: lesson duplication orchestrator.\n3\t *\n4\t * Acceptance criteria:\n5\t *  1. Orchestrator runs at most 4 strategy calls in parallel\n6\t *  2. One exercise failing does not abort the run — remaining exercises complete\n7\t *  3. Failures appear in the DB record as the run progresses (live streaming, asserted by polling)\n8\t *  4. Final status is succeeded only when failures array is empty, else needs_review\n9\t *  5. 5-exercise lesson with one forced failure → needs_review with 4 succeeded + 1 failure entry\n10\t */\n11\timport { afterAll, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest'\n12\timport { getPayload, type Payload } from 'payload'\n13\timport config from '@payload-config'\n14\t\n15\timport { getDefaultTenantSlug } from '@/server/repos/tenant/get-default-tenant'\n16\timport { runDuplicationOrchestrator } from '@/server/services/lesson-duplication/orchestrator'\n17\t\n18\t<<<<<<< HEAD\n19\t// Mock generateVariation to inject failures without hitting the LLM.\n20\t// Mocks at the LLM call site (generateVariation), intercepting before any\n21\t// network call is made. CONCURRENCY_LIMIT=1 ensures deterministic ordering.\n22\tlet generateVariationCallCount = 0\n23\tconst MOCK_BLOCKS = [\n24\t  {\n25\t    id: 'q-1',\n26\t    type: 'question_select',\n27\t    variant: 'mcq',\n28\t    selectionMode: 'single',\n29\t    prompt: { type: 'rich_text', format: 'md-math-v1', value: 'What is 2+2?', mediaIds: [] },\n30\t    answer: {\n31\t      multiSelect: false,\n32\t      options: [\n33\t        { id: 'a', content: { type: 'rich_text', format: 'md-math-v1', value: '3', mediaIds: [] } },\n34\t        { id: 'b', content: { type: 'rich_text', format: 'md-math-v1', value: '4', mediaIds: [] } },\n35\t      ],\n36\t      correctOptionIds: ['b'],\n37\t    },\n38\t    hint: { type: 'rich_text', format: 'md-math-v1', value: 'Think arithmetic', mediaIds: [] },\n39\t    solution: { type: 'rich_text', format: 'md-math-v1', value: '2+2=4', mediaIds: [] },\n40\t    fullSolution: {\n41\t      type: 'rich_text',\n42\t      format: 'md-math-v1',\n43\t      value: 'Basic addition',\n44\t      mediaIds: [],\n45\t    },\n46\t  },\n47\t]\n48\tvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n49\t  generateVariation: vi.fn().mockImplementation(async (params: { exercise: { id: string } }) => {\n50\t    generateVariationCallCount++\n51\t    // Force failure on the 5th call (4 succeed, then 1 fails)\n52\t    if (generateVariationCallCount >= 5) {\n53\t      throw new Error('Forced failure for test')\n54\t    }\n55\t    return {\n56\t      exercise: {\n57\t        ...params.exercise,\n58\t        content: { blocks: MOCK_BLOCKS },\n59\t      },\n60\t    }\n61\t  }),\n62\t=======\n63\t// Mock the variation service so AiVariationStrategy (used for medium/deep level)\n64\t// does not make real LLM calls in the integration test environment.\n65\t// The variation service is only called when level != 'none' &&\n66\t// (level != 'light' || scriptStrategy.needsAiFallback).\n67\t// Uses call-count tracking instead of ID pattern — Payload generates UUIDs for\n68\t// exercise IDs which don't contain '-3', so the old ID-based condition never triggered.\n69\tlet _vgCallCount = 0\n70\tvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n71\t  generateVariation: vi\n72\t    .fn()\n73\t    .mockImplementation(\n74\t      async (\n75\t        input: { exercise: { id: string } },\n76\t        _payload: unknown,\n77\t      ): Promise<{ exercise: { id: string; content: { blocks: unknown[] } } }> => {\n78\t        _vgCallCount++\n79\t        // Force failure on the 3rd exercise (call count 3 = index 2)\n80\t        if (_vgCallCount === 3) {\n81\t          throw new Error('Forced failure for test')\n82\t        }\n83\t        return {\n84\t          exercise: {\n85\t            id: input.exercise.id,\n86\t            content: {\n87\t              blocks: [\n88\t                {\n89\t                  id: 'q-1',\n90\t                  type: 'question_select',\n91\t                  variant: 'mcq',\n92\t                  selectionMode: 'single',\n93\t                  prompt: {\n94\t                    type: 'rich_text',\n95\t                    format: 'md-math-v1',\n96\t                    value: 'What is 2+2?',\n97\t                    mediaIds: [],\n98\t                  },\n99\t                  answer: {\n100\t                    multiSelect: false,\n101\t                    options: [\n102\t                      {\n103\t                        id: 'a',\n104\t                        content: {\n105\t                          type: 'rich_text',\n106\t                          format: 'md-math-v1',\n107\t                          value: '3',\n108\t                          mediaIds: [],\n109\t                        },\n110\t                      },\n111\t                      {\n112\t                        id: 'b',\n113\t                        content: {\n114\t                          type: 'rich_text',\n115\t                          format: 'md-math-v1',\n116\t                          value: '4',\n117\t                          mediaIds: [],\n118\t                        },\n119\t                      },\n120\t                    ],\n121\t                    correctOptionIds: ['b'],\n122\t                  },\n123\t                  hint: {\n124\t                    type: 'rich_text',\n125\t                    format: 'md-math-v1',\n126\t                    value: 'Think arithmetic',\n127\t                    mediaIds: [],\n128\t                  },\n129\t                  solution: {\n130\t                    type: 'rich_text',\n131\t                    format: 'md-math-v1',\n132\t                    value: '2+2=4',\n133\t                    mediaIds: [],\n134\t                  },\n135\t                  fullSolution: {\n136\t                    type: 'rich_text',\n137\t                    format: 'md-math-v1',\n138\t                    value: 'Basic addition',\n139\t                    mediaIds: [],\n140\t                  },\n141\t                },\n142\t              ],\n143\t            },\n144\t          },\n145\t        }\n146\t      },\n147\t    ),\n148\t>>>>>>> origin/dev\n149\t}))\n150\t\n151\tasync function ensureDefaultTenant(payload: Payload): Promise<string> {\n152\t  const slug = getDefaultTenantSlug()\n153\t  const existing = await payload.find({\n154\t    collection: 'tenants',\n155\t    where: { slug: { equals: slug } },\n156\t    limit: 1,\n157\t    overrideAccess: true,\n158\t  })\n159\t  if (existing.docs[0]) return existing.docs[0].id\n160\t  const created = await payload.create({\n161\t    collection: 'tenants',\n162\t    data: { name: slug, slug, status: 'active' },\n163\t    overrideAccess: true,\n164\t  })\n165\t  return created.id\n166\t}\n167\t\n168\tdescribe('Lesson duplication orchestrator — integration', () => {\n169\t  let payload: Payload\n170\t  let categoryId: string\n171\t  let courseId: string\n172\t  let chapterId: string\n173\t  let tenantId: string\n174\t  let sourceLessonId: string\n175\t  const cleanupLessonIds: string[] = []\n176\t  const cleanupExerciseIds: string[] = []\n177\t  const cleanupDuplicationIds: string[] = []\n178\t\n179\t  beforeEach(() => {\n180\t<<<<<<< HEAD\n181\t    generateVariationCallCount = 0\n182\t=======\n183\t    _vgCallCount = 0\n184\t>>>>>>> origin/dev\n185\t  })\n186\t\n187\t  beforeAll(async () => {\n188\t    payload = await getPayload({ config })\n189\t    tenantId = await ensureDefaultTenant(payload)\n190\t    const ts = Date.now()\n191\t\n192\t    const category = await payload.create({\n193\t      collection: 'categories',\n194\t      data: { title: `OrchCat ${ts}`, slug: `orch-cat-${ts}`, locale: 'he' },\n195\t    })\n196\t    categoryId = category.id\n197\t\n198\t    const course = await payload.create({\n199\t      collection: 'courses',\n200\t      data: {\n201\t        courseLabel: `ORCH-${ts}`,\n202\t        title: `Orch Course ${ts}`,\n203\t        locale: 'he',\n204\t        categories: [categoryId],\n205\t        order: 0,\n206\t        status: 'published',\n207\t        isActive: true,\n208\t        tenant: tenantId,\n209\t        pageAccessType: 'free',\n210\t        accessType: 'free',\n211\t        contentStatus: 'none',\n212\t        contentStatusVisible: true,\n213\t      },\n214\t      draft: false,\n215\t    })\n216\t    courseId = course.id\n217\t\n218\t    const chapter = await payload.create({\n219\t      collection: 'chapters',\n220\t      data: {\n221\t        title: `Orch Chapter ${ts}`,\n222\t        chapterLabel: `OCH-${ts}`,\n223\t        course: courseId,\n224\t        order: 0,\n225\t        status: 'published',\n226\t        isActive: true,\n227\t        tenant: tenantId,\n228\t        locale: 'he',\n229\t      },\n230\t    })\n231\t    chapterId = chapter.id\n232\t\n233\t    const lesson = await payload.create({\n234\t      collection: 'lessons',\n235\t      data: {\n236\t        title: `Orch Source Lesson ${ts}`,\n237\t        chapter: chapterId,\n238\t        type: 'practice',\n239\t        order: 1,\n240\t        status: 'published',\n241\t        isActive: true,\n242\t        tenant: tenantId,\n243\t        locale: 'he',\n244\t        accessType: 'inherit',\n245\t        contentStatus: 'none',\n246\t        contentStatusVisible: true,\n247\t      },\n248\t      draft: false,\n249\t    })\n250\t    sourceLessonId = lesson.id\n251\t    cleanupLessonIds.push(sourceLessonId)\n252\t\n253\t    // Create exactly 5 exercises on the source lesson\n254\t    for (let i = 0; i < 5; i++) {\n255\t      const ex = await payload.create({\n256\t        collection: 'exercises',\n257\t        data: { title: `Orch Exercise ${i} ${ts}`, lesson: sourceLessonId },\n258\t        draft: true,\n259\t      })\n260\t      cleanupExerciseIds.push(ex.id)\n261\t    }\n262\t  }, 120000)\n263\t\n264\t  afterAll(async () => {\n265\t    for (const id of cleanupDuplicationIds) {\n266\t      try {\n267\t        await payload.delete({ collection: 'lesson-duplications', id, overrideAccess: true })\n268\t      } catch {\n269\t        /* ignore */\n270\t      }\n271\t    }\n272\t    for (const id of cleanupExerciseIds) {\n273\t      try {\n274\t        await payload.delete({ collection: 'exercises', id, overrideAccess: true })\n275\t      } catch {\n276\t        /* ignore */\n277\t      }\n278\t    }\n279\t    for (const id of cleanupLessonIds) {\n280\t      try {\n281\t        await payload.delete({ collection: 'lessons', id, overrideAccess: true })\n282\t      } catch {\n283\t        /* ignore */\n284\t      }\n285\t    }\n286\t    try {\n287\t      await payload.delete({ collection: 'chapters', id: chapterId, overrideAccess: true })\n288\t    } catch {\n289\t      /* ignore */\n290\t    }\n291\t    try {\n292\t      await payload.delete({ collection: 'courses', id: courseId, overrideAccess: true })\n293\t    } catch {\n294\t      /* ignore */\n295\t    }\n296\t    try {\n297\t      await payload.delete({ collection: 'categories', id: categoryId, overrideAccess: true })\n298\t    } catch {\n299\t      /* ignore */\n300\t    }\n301\t    await payload.db?.destroy?.()\n302\t  })\n303\t\n304\t  /**\n305\t   * Poll the duplication record until status is no longer 'running' or 'pending'.\n306\t   * Returns the final record state.\n307\t   */\n308\t  async function pollUntilDone(recordId: string): Promise<{\n309\t    status: string\n310\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n311\t    failures: any[]\n312\t\n313\t    outputLesson?: string | null\n314\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n315\t    outputExercises?: any[]\n316\t  }> {\n317\t    let record = await payload.findByID({\n318\t      collection: 'lesson-duplications',\n319\t      id: recordId,\n320\t      depth: 0,\n321\t      overrideAccess: true,\n322\t    })\n323\t    const deadline = Date.now() + 30000\n324\t    while ((record.status === 'running' || record.status === 'pending') && Date.now() < deadline) {\n325\t      await new Promise((r) => setTimeout(r, 500))\n326\t      record = await payload.findByID({\n327\t        collection: 'lesson-duplications',\n328\t        id: recordId,\n329\t        depth: 0,\n330\t        overrideAccess: true,\n331\t      })\n332\t    }\n333\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n334\t    return record as any\n335\t  }\n336\t\n337\t  it('5-exercise lesson with one forced failure ends in needs_review with failures recorded', async () => {\n338\t    // Create pending duplication record\n339\t    const record = await payload.create({\n340\t      collection: 'lesson-duplications',\n341\t      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n342\t      overrideAccess: true,\n343\t    })\n344\t    cleanupDuplicationIds.push(record.id)\n345\t\n346\t    expect(record.status).toBe('pending')\n347\t\n348\t    // Run orchestrator (mocked generateVariation throws on 5th call)\n349\t    try {\n350\t      await runDuplicationOrchestrator(record.id, payload)\n351\t    } catch {\n352\t      // Orchestrator may throw if the mock is not properly applied;\n353\t      // we still verify the DB record state below\n354\t    }\n355\t\n356\t    // Poll until done\n357\t    const finalRecord = await pollUntilDone(record.id)\n358\t\n359\t    // Final status must be needs_review (not succeeded, not failed)\n360\t    expect(finalRecord.status).toBe('needs_review')\n361\t\n362\t    // At least one failure entry expected (5th exercise throws in generateVariation)\n363\t    expect(finalRecord.failures).toBeDefined()\n364\t    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n365\t    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n366\t    expect(finalRecord.failures[0].suggestedAction).toBe('skip')\n367\t\n368\t    // After orchestrator runs, outputLesson should be created\n369\t    // Note: outputExercises remain empty because the mock bypasses\n370\t    // createOutputExercise. Exercise creation is verified in\n371\t    // lesson-duplication-review-resolve.int.spec.ts instead.\n372\t    expect(finalRecord.outputLesson).toBeTruthy()\n373\t  }, 300000)\n374\t\n375\t  it('orchestrator does not abort when one exercise fails — remaining exercises are processed', async () => {\n376\t    // Create fresh pending record\n377\t    const record = await payload.create({\n378\t      collection: 'lesson-duplications',\n379\t      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n380\t      overrideAccess: true,\n381\t    })\n382\t    cleanupDuplicationIds.push(record.id)\n383\t\n384\t    // Run orchestrator; it may throw if the mock isn't applied (that's ok for this test)\n385\t    try {\n386\t      await runDuplicationOrchestrator(record.id, payload)\n387\t    } catch {\n388\t      // ignore\n389\t    }\n390\t\n391\t    const finalRecord = await pollUntilDone(record.id)\n392\t\n393\t    // The orchestrator should reach needs_review (not 'failed'), meaning it processed\n394\t    // exercises and collected failures rather than crashing completely.\n395\t    // If the orchestrator crashed early, status would be 'failed' with 0 failures.\n396\t    expect(finalRecord.status).toBe('needs_review')\n397\t\n398\t    // At least one failure means at least one exercise failed and the orchestrator\n399\t    // continued processing other exercises (did not abort on first failure).\n400\t    expect(finalRecord.failures).toBeDefined()\n401\t    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n402\t    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n403\t\n404\t    // outputLesson should be created even when some exercises fail\n405\t    expect(finalRecord.outputLesson).toBeTruthy()\n406\t  }, 300000)\n407\t})\n408\t"}]},"parent_tool_use_id":null,"session_id":"cc2dac12-2297-4b9b-b704-2ee288451db4","uuid":"b536159f-170e-4d26-8627-210ba9abaa57","timestamp":"2026-05-14T10:34:36.780Z","tool_use_result":{"type":"text","file":{"filePath":"/home/runner/work/A-Guy/A-Guy/tests/int/lesson-duplication-orchestrator.int.spec.ts","content":"/**\n * Integration test: lesson duplication orchestrator.\n *\n * Acceptance criteria:\n *  1. Orchestrator runs at most 4 strategy calls in parallel\n *  2. One exercise failing does not abort the run — remaining exercises complete\n *  3. Failures appear in the DB record as the run progresses (live streaming, asserted by polling)\n *  4. Final status is succeeded only when failures array is empty, else needs_review\n *  5. 5-exercise lesson with one forced failure → needs_review with 4 succeeded + 1 failure entry\n */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest'\nimport { getPayload, type Payload } from 'payload'\nimport config from '@payload-config'\n\nimport { getDefaultTenantSlug } from '@/server/repos/tenant/get-default-tenant'\nimport { runDuplicationOrchestrator } from '@/server/services/lesson-duplication/orchestrator'\n\n<<<<<<< HEAD\n// Mock generateVariation to inject failures without hitting the LLM.\n// Mocks at the LLM call site (generateVariation), intercepting before any\n// network call is made. CONCURRENCY_LIMIT=1 ensures deterministic ordering.\nlet generateVariationCallCount = 0\nconst MOCK_BLOCKS = [\n  {\n    id: 'q-1',\n    type: 'question_select',\n    variant: 'mcq',\n    selectionMode: 'single',\n    prompt: { type: 'rich_text', format: 'md-math-v1', value: 'What is 2+2?', mediaIds: [] },\n    answer: {\n      multiSelect: false,\n      options: [\n        { id: 'a', content: { type: 'rich_text', format: 'md-math-v1', value: '3', mediaIds: [] } },\n        { id: 'b', content: { type: 'rich_text', format: 'md-math-v1', value: '4', mediaIds: [] } },\n      ],\n      correctOptionIds: ['b'],\n    },\n    hint: { type: 'rich_text', format: 'md-math-v1', value: 'Think arithmetic', mediaIds: [] },\n    solution: { type: 'rich_text', format: 'md-math-v1', value: '2+2=4', mediaIds: [] },\n    fullSolution: {\n      type: 'rich_text',\n      format: 'md-math-v1',\n      value: 'Basic addition',\n      mediaIds: [],\n    },\n  },\n]\nvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n  generateVariation: vi.fn().mockImplementation(async (params: { exercise: { id: string } }) => {\n    generateVariationCallCount++\n    // Force failure on the 5th call (4 succeed, then 1 fails)\n    if (generateVariationCallCount >= 5) {\n      throw new Error('Forced failure for test')\n    }\n    return {\n      exercise: {\n        ...params.exercise,\n        content: { blocks: MOCK_BLOCKS },\n      },\n    }\n  }),\n=======\n// Mock the variation service so AiVariationStrategy (used for medium/deep level)\n// does not make real LLM calls in the integration test environment.\n// The variation service is only called when level != 'none' &&\n// (level != 'light' || scriptStrategy.needsAiFallback).\n// Uses call-count tracking instead of ID pattern — Payload generates UUIDs for\n// exercise IDs which don't contain '-3', so the old ID-based condition never triggered.\nlet _vgCallCount = 0\nvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n  generateVariation: vi\n    .fn()\n    .mockImplementation(\n      async (\n        input: { exercise: { id: string } },\n        _payload: unknown,\n      ): Promise<{ exercise: { id: string; content: { blocks: unknown[] } } }> => {\n        _vgCallCount++\n        // Force failure on the 3rd exercise (call count 3 = index 2)\n        if (_vgCallCount === 3) {\n          throw new Error('Forced failure for test')\n        }\n        return {\n          exercise: {\n            id: input.exercise.id,\n            content: {\n              blocks: [\n                {\n                  id: 'q-1',\n                  type: 'question_select',\n                  variant: 'mcq',\n                  selectionMode: 'single',\n                  prompt: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: 'What is 2+2?',\n                    mediaIds: [],\n                  },\n                  answer: {\n                    multiSelect: false,\n                    options: [\n                      {\n                        id: 'a',\n                        content: {\n                          type: 'rich_text',\n                          format: 'md-math-v1',\n                          value: '3',\n                          mediaIds: [],\n                        },\n                      },\n                      {\n                        id: 'b',\n                        content: {\n                          type: 'rich_text',\n                          format: 'md-math-v1',\n                          value: '4',\n                          mediaIds: [],\n                        },\n                      },\n                    ],\n                    correctOptionIds: ['b'],\n                  },\n                  hint: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: 'Think arithmetic',\n                    mediaIds: [],\n                  },\n                  solution: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: '2+2=4',\n                    mediaIds: [],\n                  },\n                  fullSolution: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: 'Basic addition',\n                    mediaIds: [],\n                  },\n                },\n              ],\n            },\n          },\n        }\n      },\n    ),\n>>>>>>> origin/dev\n}))\n\nasync function ensureDefaultTenant(payload: Payload): Promise<string> {\n  const slug = getDefaultTenantSlug()\n  const existing = await payload.find({\n    collection: 'tenants',\n    where: { slug: { equals: slug } },\n    limit: 1,\n    overrideAccess: true,\n  })\n  if (existing.docs[0]) return existing.docs[0].id\n  const created = await payload.create({\n    collection: 'tenants',\n    data: { name: slug, slug, status: 'active' },\n    overrideAccess: true,\n  })\n  return created.id\n}\n\ndescribe('Lesson duplication orchestrator — integration', () => {\n  let payload: Payload\n  let categoryId: string\n  let courseId: string\n  let chapterId: string\n  let tenantId: string\n  let sourceLessonId: string\n  const cleanupLessonIds: string[] = []\n  const cleanupExerciseIds: string[] = []\n  const cleanupDuplicationIds: string[] = []\n\n  beforeEach(() => {\n<<<<<<< HEAD\n    generateVariationCallCount = 0\n=======\n    _vgCallCount = 0\n>>>>>>> origin/dev\n  })\n\n  beforeAll(async () => {\n    payload = await getPayload({ config })\n    tenantId = await ensureDefaultTenant(payload)\n    const ts = Date.now()\n\n    const category = await payload.create({\n      collection: 'categories',\n      data: { title: `OrchCat ${ts}`, slug: `orch-cat-${ts}`, locale: 'he' },\n    })\n    categoryId = category.id\n\n    const course = await payload.create({\n      collection: 'courses',\n      data: {\n        courseLabel: `ORCH-${ts}`,\n        title: `Orch Course ${ts}`,\n        locale: 'he',\n        categories: [categoryId],\n        order: 0,\n        status: 'published',\n        isActive: true,\n        tenant: tenantId,\n        pageAccessType: 'free',\n        accessType: 'free',\n        contentStatus: 'none',\n        contentStatusVisible: true,\n      },\n      draft: false,\n    })\n    courseId = course.id\n\n    const chapter = await payload.create({\n      collection: 'chapters',\n      data: {\n        title: `Orch Chapter ${ts}`,\n        chapterLabel: `OCH-${ts}`,\n        course: courseId,\n        order: 0,\n        status: 'published',\n        isActive: true,\n        tenant: tenantId,\n        locale: 'he',\n      },\n    })\n    chapterId = chapter.id\n\n    const lesson = await payload.create({\n      collection: 'lessons',\n      data: {\n        title: `Orch Source Lesson ${ts}`,\n        chapter: chapterId,\n        type: 'practice',\n        order: 1,\n        status: 'published',\n        isActive: true,\n        tenant: tenantId,\n        locale: 'he',\n        accessType: 'inherit',\n        contentStatus: 'none',\n        contentStatusVisible: true,\n      },\n      draft: false,\n    })\n    sourceLessonId = lesson.id\n    cleanupLessonIds.push(sourceLessonId)\n\n    // Create exactly 5 exercises on the source lesson\n    for (let i = 0; i < 5; i++) {\n      const ex = await payload.create({\n        collection: 'exercises',\n        data: { title: `Orch Exercise ${i} ${ts}`, lesson: sourceLessonId },\n        draft: true,\n      })\n      cleanupExerciseIds.push(ex.id)\n    }\n  }, 120000)\n\n  afterAll(async () => {\n    for (const id of cleanupDuplicationIds) {\n      try {\n        await payload.delete({ collection: 'lesson-duplications', id, overrideAccess: true })\n      } catch {\n        /* ignore */\n      }\n    }\n    for (const id of cleanupExerciseIds) {\n      try {\n        await payload.delete({ collection: 'exercises', id, overrideAccess: true })\n      } catch {\n        /* ignore */\n      }\n    }\n    for (const id of cleanupLessonIds) {\n      try {\n        await payload.delete({ collection: 'lessons', id, overrideAccess: true })\n      } catch {\n        /* ignore */\n      }\n    }\n    try {\n      await payload.delete({ collection: 'chapters', id: chapterId, overrideAccess: true })\n    } catch {\n      /* ignore */\n    }\n    try {\n      await payload.delete({ collection: 'courses', id: courseId, overrideAccess: true })\n    } catch {\n      /* ignore */\n    }\n    try {\n      await payload.delete({ collection: 'categories', id: categoryId, overrideAccess: true })\n    } catch {\n      /* ignore */\n    }\n    await payload.db?.destroy?.()\n  })\n\n  /**\n   * Poll the duplication record until status is no longer 'running' or 'pending'.\n   * Returns the final record state.\n   */\n  async function pollUntilDone(recordId: string): Promise<{\n    status: string\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    failures: any[]\n\n    outputLesson?: string | null\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    outputExercises?: any[]\n  }> {\n    let record = await payload.findByID({\n      collection: 'lesson-duplications',\n      id: recordId,\n      depth: 0,\n      overrideAccess: true,\n    })\n    const deadline = Date.now() + 30000\n    while ((record.status === 'running' || record.status === 'pending') && Date.now() < deadline) {\n      await new Promise((r) => setTimeout(r, 500))\n      record = await payload.findByID({\n        collection: 'lesson-duplications',\n        id: recordId,\n        depth: 0,\n        overrideAccess: true,\n      })\n    }\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    return record as any\n  }\n\n  it('5-exercise lesson with one forced failure ends in needs_review with failures recorded', async () => {\n    // Create pending duplication record\n    const record = await payload.create({\n      collection: 'lesson-duplications',\n      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n      overrideAccess: true,\n    })\n    cleanupDuplicationIds.push(record.id)\n\n    expect(record.status).toBe('pending')\n\n    // Run orchestrator (mocked generateVariation throws on 5th call)\n    try {\n      await runDuplicationOrchestrator(record.id, payload)\n    } catch {\n      // Orchestrator may throw if the mock is not properly applied;\n      // we still verify the DB record state below\n    }\n\n    // Poll until done\n    const finalRecord = await pollUntilDone(record.id)\n\n    // Final status must be needs_review (not succeeded, not failed)\n    expect(finalRecord.status).toBe('needs_review')\n\n    // At least one failure entry expected (5th exercise throws in generateVariation)\n    expect(finalRecord.failures).toBeDefined()\n    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n    expect(finalRecord.failures[0].suggestedAction).toBe('skip')\n\n    // After orchestrator runs, outputLesson should be created\n    // Note: outputExercises remain empty because the mock bypasses\n    // createOutputExercise. Exercise creation is verified in\n    // lesson-duplication-review-resolve.int.spec.ts instead.\n    expect(finalRecord.outputLesson).toBeTruthy()\n  }, 300000)\n\n  it('orchestrator does not abort when one exercise fails — remaining exercises are processed', async () => {\n    // Create fresh pending record\n    const record = await payload.create({\n      collection: 'lesson-duplications',\n      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n      overrideAccess: true,\n    })\n    cleanupDuplicationIds.push(record.id)\n\n    // Run orchestrator; it may throw if the mock isn't applied (that's ok for this test)\n    try {\n      await runDuplicationOrchestrator(record.id, payload)\n    } catch {\n      // ignore\n    }\n\n    const finalRecord = await pollUntilDone(record.id)\n\n    // The orchestrator should reach needs_review (not 'failed'), meaning it processed\n    // exercises and collected failures rather than crashing completely.\n    // If the orchestrator crashed early, status would be 'failed' with 0 failures.\n    expect(finalRecord.status).toBe('needs_review')\n\n    // At least one failure means at least one exercise failed and the orchestrator\n    // continued processing other exercises (did not abort on first failure).\n    expect(finalRecord.failures).toBeDefined()\n    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n\n    // outputLesson should be created even when some exercises fail\n    expect(finalRecord.outputLesson).toBeTruthy()\n  }, 300000)\n})\n","numLines":408,"startLine":1,"totalLines":408}}}
