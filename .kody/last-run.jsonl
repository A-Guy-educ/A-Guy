{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_xq0mxf3b3uks_1","type":"tool_result","content":"1\t/**\n2\t * Integration test: lesson duplication orchestrator.\n3\t *\n4\t * Acceptance criteria:\n5\t *  1. Orchestrator runs at most 4 strategy calls in parallel\n6\t *  2. One exercise failing does not abort the run — remaining exercises complete\n7\t *  3. Failures appear in the DB record as the run progresses (live streaming, asserted by polling)\n8\t *  4. Final status is succeeded only when failures array is empty, else needs_review\n9\t *  5. 5-exercise lesson with one forced failure → needs_review with 4 succeeded + 1 failure entry\n10\t */\n11\timport { afterAll, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest'\n12\timport { getPayload, type Payload } from 'payload'\n13\timport config from '@payload-config'\n14\t\n15\timport { getDefaultTenantSlug } from '@/server/repos/tenant/get-default-tenant'\n16\timport { runDuplicationOrchestrator } from '@/server/services/lesson-duplication/orchestrator'\n17\t\n18\t<<<<<<< HEAD\n19\t// Mock runStrategy to inject one forced failure on the 3rd exercise.\n20\t// Also mock generateVariation at source so the AI path is fully intercepted even if\n21\t// vi.mock of the orchestrator module is not applied (VI module-cache can return the\n22\t// already-modified module from importOriginal, causing the unmocked AiVariationStrategy\n23\t// path to run and hang on LLM calls without an API key).\n24\tvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n25\t  generateVariation: vi.fn().mockResolvedValue({\n26\t    exercise: {\n27\t      id: 'mock-exercise',\n28\t      content: { blocks: [] },\n29\t    },\n30\t  }),\n31\t}))\n32\t\n33\tvi.mock('@/server/services/lesson-duplication/orchestrator', async (importOriginal) => {\n34\t  const actual =\n35\t    await importOriginal<typeof import('@/server/services/lesson-duplication/orchestrator')>()\n36\t  return {\n37\t    ...actual,\n38\t    runStrategy: vi\n39\t      .fn()\n40\t      .mockImplementation(\n41\t        async (exercise: { id: string }, _level: string, _subject: unknown, _payload: unknown) => {\n42\t          // Force failure on the 3rd exercise (index-based)\n43\t          if (exercise.id.includes('-3')) {\n44\t            throw new Error('Forced failure for test')\n45\t          }\n46\t          // Use strategy='script' to bypass semantic validation (avoids LLM calls in tests)\n47\t          return {\n48\t            exerciseId: exercise.id,\n49\t            strategy: 'script' as const,\n50\t            blocks: [\n51\t              {\n52\t                id: 'q-1',\n53\t                type: 'question_select',\n54\t                variant: 'mcq',\n55\t                selectionMode: 'single',\n56\t                prompt: {\n57\t                  type: 'rich_text',\n58\t                  format: 'md-math-v1',\n59\t                  value: 'What is 2+2?',\n60\t                  mediaIds: [],\n61\t                },\n62\t                answer: {\n63\t                  multiSelect: false,\n64\t                  options: [\n65\t                    {\n66\t                      id: 'a',\n67\t                      content: {\n68\t                        type: 'rich_text',\n69\t                        format: 'md-math-v1',\n70\t                        value: '3',\n71\t                        mediaIds: [],\n72\t=======\n73\t// Mock the variation service so AiVariationStrategy (used for medium/deep level)\n74\t// does not make real LLM calls in the integration test environment.\n75\t// The variation service is only called when level != 'none' &&\n76\t// (level != 'light' || scriptStrategy.needsAiFallback).\n77\t// Uses call-count tracking instead of ID pattern — Payload generates UUIDs for\n78\t// exercise IDs which don't contain '-3', so the old ID-based condition never triggered.\n79\tlet _vgCallCount = 0\n80\tvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n81\t  generateVariation: vi\n82\t    .fn()\n83\t    .mockImplementation(\n84\t      async (\n85\t        input: { exercise: { id: string } },\n86\t        _payload: unknown,\n87\t      ): Promise<{ exercise: { id: string; content: { blocks: unknown[] } } }> => {\n88\t        _vgCallCount++\n89\t        // Force failure on the 3rd exercise (call count 3 = index 2)\n90\t        if (_vgCallCount === 3) {\n91\t          throw new Error('Forced failure for test')\n92\t        }\n93\t        return {\n94\t          exercise: {\n95\t            id: input.exercise.id,\n96\t            content: {\n97\t              blocks: [\n98\t                {\n99\t                  id: 'q-1',\n100\t                  type: 'question_select',\n101\t                  variant: 'mcq',\n102\t                  selectionMode: 'single',\n103\t                  prompt: {\n104\t                    type: 'rich_text',\n105\t                    format: 'md-math-v1',\n106\t                    value: 'What is 2+2?',\n107\t                    mediaIds: [],\n108\t                  },\n109\t                  answer: {\n110\t                    multiSelect: false,\n111\t                    options: [\n112\t                      {\n113\t                        id: 'a',\n114\t                        content: {\n115\t                          type: 'rich_text',\n116\t                          format: 'md-math-v1',\n117\t                          value: '3',\n118\t                          mediaIds: [],\n119\t                        },\n120\t>>>>>>> origin/dev\n121\t                      },\n122\t                      {\n123\t                        id: 'b',\n124\t                        content: {\n125\t                          type: 'rich_text',\n126\t                          format: 'md-math-v1',\n127\t                          value: '4',\n128\t                          mediaIds: [],\n129\t                        },\n130\t                      },\n131\t                    ],\n132\t                    correctOptionIds: ['b'],\n133\t                  },\n134\t                  hint: {\n135\t                    type: 'rich_text',\n136\t                    format: 'md-math-v1',\n137\t                    value: 'Think arithmetic',\n138\t                    mediaIds: [],\n139\t                  },\n140\t                  solution: {\n141\t                    type: 'rich_text',\n142\t                    format: 'md-math-v1',\n143\t                    value: '2+2=4',\n144\t                    mediaIds: [],\n145\t                  },\n146\t                  fullSolution: {\n147\t                    type: 'rich_text',\n148\t                    format: 'md-math-v1',\n149\t                    value: 'Basic addition',\n150\t                    mediaIds: [],\n151\t                  },\n152\t                },\n153\t              ],\n154\t            },\n155\t          },\n156\t        }\n157\t      },\n158\t    ),\n159\t}))\n160\t\n161\tasync function ensureDefaultTenant(payload: Payload): Promise<string> {\n162\t  const slug = getDefaultTenantSlug()\n163\t  const existing = await payload.find({\n164\t    collection: 'tenants',\n165\t    where: { slug: { equals: slug } },\n166\t    limit: 1,\n167\t    overrideAccess: true,\n168\t  })\n169\t  if (existing.docs[0]) return existing.docs[0].id\n170\t  const created = await payload.create({\n171\t    collection: 'tenants',\n172\t    data: { name: slug, slug, status: 'active' },\n173\t    overrideAccess: true,\n174\t  })\n175\t  return created.id\n176\t}\n177\t\n178\tdescribe('Lesson duplication orchestrator — integration', () => {\n179\t  let payload: Payload\n180\t  let categoryId: string\n181\t  let courseId: string\n182\t  let chapterId: string\n183\t  let tenantId: string\n184\t  let sourceLessonId: string\n185\t  const cleanupLessonIds: string[] = []\n186\t  const cleanupExerciseIds: string[] = []\n187\t  const cleanupDuplicationIds: string[] = []\n188\t\n189\t  beforeEach(() => {\n190\t    _vgCallCount = 0\n191\t  })\n192\t\n193\t  beforeAll(async () => {\n194\t    payload = await getPayload({ config })\n195\t    tenantId = await ensureDefaultTenant(payload)\n196\t    const ts = Date.now()\n197\t\n198\t    const category = await payload.create({\n199\t      collection: 'categories',\n200\t      data: { title: `OrchCat ${ts}`, slug: `orch-cat-${ts}`, locale: 'he' },\n201\t    })\n202\t    categoryId = category.id\n203\t\n204\t    const course = await payload.create({\n205\t      collection: 'courses',\n206\t      data: {\n207\t        courseLabel: `ORCH-${ts}`,\n208\t        title: `Orch Course ${ts}`,\n209\t        locale: 'he',\n210\t        categories: [categoryId],\n211\t        order: 0,\n212\t        status: 'published',\n213\t        isActive: true,\n214\t        tenant: tenantId,\n215\t        pageAccessType: 'free',\n216\t        accessType: 'free',\n217\t        contentStatus: 'none',\n218\t        contentStatusVisible: true,\n219\t      },\n220\t      draft: false,\n221\t    })\n222\t    courseId = course.id\n223\t\n224\t    const chapter = await payload.create({\n225\t      collection: 'chapters',\n226\t      data: {\n227\t        title: `Orch Chapter ${ts}`,\n228\t        chapterLabel: `OCH-${ts}`,\n229\t        course: courseId,\n230\t        order: 0,\n231\t        status: 'published',\n232\t        isActive: true,\n233\t        tenant: tenantId,\n234\t        locale: 'he',\n235\t      },\n236\t    })\n237\t    chapterId = chapter.id\n238\t\n239\t    const lesson = await payload.create({\n240\t      collection: 'lessons',\n241\t      data: {\n242\t        title: `Orch Source Lesson ${ts}`,\n243\t        chapter: chapterId,\n244\t        type: 'practice',\n245\t        order: 1,\n246\t        status: 'published',\n247\t        isActive: true,\n248\t        tenant: tenantId,\n249\t        locale: 'he',\n250\t        accessType: 'inherit',\n251\t        contentStatus: 'none',\n252\t        contentStatusVisible: true,\n253\t      },\n254\t      draft: false,\n255\t    })\n256\t    sourceLessonId = lesson.id\n257\t    cleanupLessonIds.push(sourceLessonId)\n258\t\n259\t    // Create exactly 5 exercises on the source lesson\n260\t    for (let i = 0; i < 5; i++) {\n261\t      const ex = await payload.create({\n262\t        collection: 'exercises',\n263\t        data: { title: `Orch Exercise ${i} ${ts}`, lesson: sourceLessonId },\n264\t        draft: true,\n265\t      })\n266\t      cleanupExerciseIds.push(ex.id)\n267\t    }\n268\t  }, 120000)\n269\t\n270\t  afterAll(async () => {\n271\t    for (const id of cleanupDuplicationIds) {\n272\t      try {\n273\t        await payload.delete({ collection: 'lesson-duplications', id, overrideAccess: true })\n274\t      } catch {\n275\t        /* ignore */\n276\t      }\n277\t    }\n278\t    for (const id of cleanupExerciseIds) {\n279\t      try {\n280\t        await payload.delete({ collection: 'exercises', id, overrideAccess: true })\n281\t      } catch {\n282\t        /* ignore */\n283\t      }\n284\t    }\n285\t    for (const id of cleanupLessonIds) {\n286\t      try {\n287\t        await payload.delete({ collection: 'lessons', id, overrideAccess: true })\n288\t      } catch {\n289\t        /* ignore */\n290\t      }\n291\t    }\n292\t    try {\n293\t      await payload.delete({ collection: 'chapters', id: chapterId, overrideAccess: true })\n294\t    } catch {\n295\t      /* ignore */\n296\t    }\n297\t    try {\n298\t      await payload.delete({ collection: 'courses', id: courseId, overrideAccess: true })\n299\t    } catch {\n300\t      /* ignore */\n301\t    }\n302\t    try {\n303\t      await payload.delete({ collection: 'categories', id: categoryId, overrideAccess: true })\n304\t    } catch {\n305\t      /* ignore */\n306\t    }\n307\t    await payload.db?.destroy?.()\n308\t  })\n309\t\n310\t  /**\n311\t   * Poll the duplication record until status is no longer 'running' or 'pending'.\n312\t   * Returns the final record state.\n313\t   */\n314\t  async function pollUntilDone(recordId: string): Promise<{\n315\t    status: string\n316\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n317\t    failures: any[]\n318\t\n319\t    outputLesson?: string | null\n320\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n321\t    outputExercises?: any[]\n322\t  }> {\n323\t    let record = await payload.findByID({\n324\t      collection: 'lesson-duplications',\n325\t      id: recordId,\n326\t      depth: 0,\n327\t      overrideAccess: true,\n328\t    })\n329\t    const deadline = Date.now() + 30000\n330\t    while ((record.status === 'running' || record.status === 'pending') && Date.now() < deadline) {\n331\t      await new Promise((r) => setTimeout(r, 500))\n332\t      record = await payload.findByID({\n333\t        collection: 'lesson-duplications',\n334\t        id: recordId,\n335\t        depth: 0,\n336\t        overrideAccess: true,\n337\t      })\n338\t    }\n339\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n340\t    return record as any\n341\t  }\n342\t\n343\t  it('5-exercise lesson with one forced failure ends in needs_review with failures recorded', async () => {\n344\t    // Create pending duplication record\n345\t    const record = await payload.create({\n346\t      collection: 'lesson-duplications',\n347\t      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n348\t      overrideAccess: true,\n349\t    })\n350\t    cleanupDuplicationIds.push(record.id)\n351\t\n352\t    expect(record.status).toBe('pending')\n353\t\n354\t    // Run orchestrator (mocked runStrategy forces failure on exercise containing '-3')\n355\t    try {\n356\t      await runDuplicationOrchestrator(record.id, payload)\n357\t    } catch {\n358\t      // Orchestrator may throw if the mock is not properly applied;\n359\t      // we still verify the DB record state below\n360\t    }\n361\t\n362\t    // Poll until done\n363\t    const finalRecord = await pollUntilDone(record.id)\n364\t\n365\t    // Final status must be needs_review (not succeeded, not failed)\n366\t    expect(finalRecord.status).toBe('needs_review')\n367\t\n368\t    // At least one failure entry expected (exercise containing '-3' threw in runStrategy)\n369\t    // Note: the exact count depends on exercise ID strings; we check ≥1 to be robust\n370\t    expect(finalRecord.failures).toBeDefined()\n371\t    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n372\t    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n373\t    expect(finalRecord.failures[0].suggestedAction).toBe('skip')\n374\t\n375\t    // After orchestrator runs, outputLesson should be created\n376\t    // Note: outputExercises remain empty in this test because the runStrategy mock\n377\t    // bypasses processExercise (which calls createOutputExercise). Exercise creation\n378\t    // is verified in lesson-duplication-review-resolve.int.spec.ts instead.\n379\t    expect(finalRecord.outputLesson).toBeTruthy()\n380\t  }, 180000)\n381\t\n382\t  it('orchestrator does not abort when one exercise fails — remaining exercises are processed', async () => {\n383\t    // Create fresh pending record\n384\t    const record = await payload.create({\n385\t      collection: 'lesson-duplications',\n386\t      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n387\t      overrideAccess: true,\n388\t    })\n389\t    cleanupDuplicationIds.push(record.id)\n390\t\n391\t    // Run orchestrator; it may throw if the mock isn't applied (that's ok for this test)\n392\t    try {\n393\t      await runDuplicationOrchestrator(record.id, payload)\n394\t    } catch {\n395\t      // ignore\n396\t    }\n397\t\n398\t    const finalRecord = await pollUntilDone(record.id)\n399\t\n400\t    // The orchestrator should reach needs_review (not 'failed'), meaning it processed\n401\t    // exercises and collected failures rather than crashing completely.\n402\t    // If the orchestrator crashed early, status would be 'failed' with 0 failures.\n403\t    expect(finalRecord.status).toBe('needs_review')\n404\t\n405\t    // At least one failure means at least one exercise failed and the orchestrator\n406\t    // continued processing other exercises (did not abort on first failure).\n407\t    expect(finalRecord.failures).toBeDefined()\n408\t    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n409\t    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n410\t\n411\t    // outputLesson should be created even when some exercises fail\n412\t    expect(finalRecord.outputLesson).toBeTruthy()\n413\t  }, 180000)\n414\t})\n415\t"}]},"parent_tool_use_id":null,"session_id":"902de79c-39c6-420e-9adb-32b0d716750a","uuid":"9c18bfbc-5010-41a4-97f1-cad55415a919","timestamp":"2026-05-14T10:32:55.851Z","tool_use_result":{"type":"text","file":{"filePath":"/home/runner/work/A-Guy/A-Guy/tests/int/lesson-duplication-orchestrator.int.spec.ts","content":"/**\n * Integration test: lesson duplication orchestrator.\n *\n * Acceptance criteria:\n *  1. Orchestrator runs at most 4 strategy calls in parallel\n *  2. One exercise failing does not abort the run — remaining exercises complete\n *  3. Failures appear in the DB record as the run progresses (live streaming, asserted by polling)\n *  4. Final status is succeeded only when failures array is empty, else needs_review\n *  5. 5-exercise lesson with one forced failure → needs_review with 4 succeeded + 1 failure entry\n */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest'\nimport { getPayload, type Payload } from 'payload'\nimport config from '@payload-config'\n\nimport { getDefaultTenantSlug } from '@/server/repos/tenant/get-default-tenant'\nimport { runDuplicationOrchestrator } from '@/server/services/lesson-duplication/orchestrator'\n\n<<<<<<< HEAD\n// Mock runStrategy to inject one forced failure on the 3rd exercise.\n// Also mock generateVariation at source so the AI path is fully intercepted even if\n// vi.mock of the orchestrator module is not applied (VI module-cache can return the\n// already-modified module from importOriginal, causing the unmocked AiVariationStrategy\n// path to run and hang on LLM calls without an API key).\nvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n  generateVariation: vi.fn().mockResolvedValue({\n    exercise: {\n      id: 'mock-exercise',\n      content: { blocks: [] },\n    },\n  }),\n}))\n\nvi.mock('@/server/services/lesson-duplication/orchestrator', async (importOriginal) => {\n  const actual =\n    await importOriginal<typeof import('@/server/services/lesson-duplication/orchestrator')>()\n  return {\n    ...actual,\n    runStrategy: vi\n      .fn()\n      .mockImplementation(\n        async (exercise: { id: string }, _level: string, _subject: unknown, _payload: unknown) => {\n          // Force failure on the 3rd exercise (index-based)\n          if (exercise.id.includes('-3')) {\n            throw new Error('Forced failure for test')\n          }\n          // Use strategy='script' to bypass semantic validation (avoids LLM calls in tests)\n          return {\n            exerciseId: exercise.id,\n            strategy: 'script' as const,\n            blocks: [\n              {\n                id: 'q-1',\n                type: 'question_select',\n                variant: 'mcq',\n                selectionMode: 'single',\n                prompt: {\n                  type: 'rich_text',\n                  format: 'md-math-v1',\n                  value: 'What is 2+2?',\n                  mediaIds: [],\n                },\n                answer: {\n                  multiSelect: false,\n                  options: [\n                    {\n                      id: 'a',\n                      content: {\n                        type: 'rich_text',\n                        format: 'md-math-v1',\n                        value: '3',\n                        mediaIds: [],\n=======\n// Mock the variation service so AiVariationStrategy (used for medium/deep level)\n// does not make real LLM calls in the integration test environment.\n// The variation service is only called when level != 'none' &&\n// (level != 'light' || scriptStrategy.needsAiFallback).\n// Uses call-count tracking instead of ID pattern — Payload generates UUIDs for\n// exercise IDs which don't contain '-3', so the old ID-based condition never triggered.\nlet _vgCallCount = 0\nvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n  generateVariation: vi\n    .fn()\n    .mockImplementation(\n      async (\n        input: { exercise: { id: string } },\n        _payload: unknown,\n      ): Promise<{ exercise: { id: string; content: { blocks: unknown[] } } }> => {\n        _vgCallCount++\n        // Force failure on the 3rd exercise (call count 3 = index 2)\n        if (_vgCallCount === 3) {\n          throw new Error('Forced failure for test')\n        }\n        return {\n          exercise: {\n            id: input.exercise.id,\n            content: {\n              blocks: [\n                {\n                  id: 'q-1',\n                  type: 'question_select',\n                  variant: 'mcq',\n                  selectionMode: 'single',\n                  prompt: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: 'What is 2+2?',\n                    mediaIds: [],\n                  },\n                  answer: {\n                    multiSelect: false,\n                    options: [\n                      {\n                        id: 'a',\n                        content: {\n                          type: 'rich_text',\n                          format: 'md-math-v1',\n                          value: '3',\n                          mediaIds: [],\n                        },\n>>>>>>> origin/dev\n                      },\n                      {\n                        id: 'b',\n                        content: {\n                          type: 'rich_text',\n                          format: 'md-math-v1',\n                          value: '4',\n                          mediaIds: [],\n                        },\n                      },\n                    ],\n                    correctOptionIds: ['b'],\n                  },\n                  hint: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: 'Think arithmetic',\n                    mediaIds: [],\n                  },\n                  solution: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: '2+2=4',\n                    mediaIds: [],\n                  },\n                  fullSolution: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: 'Basic addition',\n                    mediaIds: [],\n                  },\n                },\n              ],\n            },\n          },\n        }\n      },\n    ),\n}))\n\nasync function ensureDefaultTenant(payload: Payload): Promise<string> {\n  const slug = getDefaultTenantSlug()\n  const existing = await payload.find({\n    collection: 'tenants',\n    where: { slug: { equals: slug } },\n    limit: 1,\n    overrideAccess: true,\n  })\n  if (existing.docs[0]) return existing.docs[0].id\n  const created = await payload.create({\n    collection: 'tenants',\n    data: { name: slug, slug, status: 'active' },\n    overrideAccess: true,\n  })\n  return created.id\n}\n\ndescribe('Lesson duplication orchestrator — integration', () => {\n  let payload: Payload\n  let categoryId: string\n  let courseId: string\n  let chapterId: string\n  let tenantId: string\n  let sourceLessonId: string\n  const cleanupLessonIds: string[] = []\n  const cleanupExerciseIds: string[] = []\n  const cleanupDuplicationIds: string[] = []\n\n  beforeEach(() => {\n    _vgCallCount = 0\n  })\n\n  beforeAll(async () => {\n    payload = await getPayload({ config })\n    tenantId = await ensureDefaultTenant(payload)\n    const ts = Date.now()\n\n    const category = await payload.create({\n      collection: 'categories',\n      data: { title: `OrchCat ${ts}`, slug: `orch-cat-${ts}`, locale: 'he' },\n    })\n    categoryId = category.id\n\n    const course = await payload.create({\n      collection: 'courses',\n      data: {\n        courseLabel: `ORCH-${ts}`,\n        title: `Orch Course ${ts}`,\n        locale: 'he',\n        categories: [categoryId],\n        order: 0,\n        status: 'published',\n        isActive: true,\n        tenant: tenantId,\n        pageAccessType: 'free',\n        accessType: 'free',\n        contentStatus: 'none',\n        contentStatusVisible: true,\n      },\n      draft: false,\n    })\n    courseId = course.id\n\n    const chapter = await payload.create({\n      collection: 'chapters',\n      data: {\n        title: `Orch Chapter ${ts}`,\n        chapterLabel: `OCH-${ts}`,\n        course: courseId,\n        order: 0,\n        status: 'published',\n        isActive: true,\n        tenant: tenantId,\n        locale: 'he',\n      },\n    })\n    chapterId = chapter.id\n\n    const lesson = await payload.create({\n      collection: 'lessons',\n      data: {\n        title: `Orch Source Lesson ${ts}`,\n        chapter: chapterId,\n        type: 'practice',\n        order: 1,\n        status: 'published',\n        isActive: true,\n        tenant: tenantId,\n        locale: 'he',\n        accessType: 'inherit',\n        contentStatus: 'none',\n        contentStatusVisible: true,\n      },\n      draft: false,\n    })\n    sourceLessonId = lesson.id\n    cleanupLessonIds.push(sourceLessonId)\n\n    // Create exactly 5 exercises on the source lesson\n    for (let i = 0; i < 5; i++) {\n      const ex = await payload.create({\n        collection: 'exercises',\n        data: { title: `Orch Exercise ${i} ${ts}`, lesson: sourceLessonId },\n        draft: true,\n      })\n      cleanupExerciseIds.push(ex.id)\n    }\n  }, 120000)\n\n  afterAll(async () => {\n    for (const id of cleanupDuplicationIds) {\n      try {\n        await payload.delete({ collection: 'lesson-duplications', id, overrideAccess: true })\n      } catch {\n        /* ignore */\n      }\n    }\n    for (const id of cleanupExerciseIds) {\n      try {\n        await payload.delete({ collection: 'exercises', id, overrideAccess: true })\n      } catch {\n        /* ignore */\n      }\n    }\n    for (const id of cleanupLessonIds) {\n      try {\n        await payload.delete({ collection: 'lessons', id, overrideAccess: true })\n      } catch {\n        /* ignore */\n      }\n    }\n    try {\n      await payload.delete({ collection: 'chapters', id: chapterId, overrideAccess: true })\n    } catch {\n      /* ignore */\n    }\n    try {\n      await payload.delete({ collection: 'courses', id: courseId, overrideAccess: true })\n    } catch {\n      /* ignore */\n    }\n    try {\n      await payload.delete({ collection: 'categories', id: categoryId, overrideAccess: true })\n    } catch {\n      /* ignore */\n    }\n    await payload.db?.destroy?.()\n  })\n\n  /**\n   * Poll the duplication record until status is no longer 'running' or 'pending'.\n   * Returns the final record state.\n   */\n  async function pollUntilDone(recordId: string): Promise<{\n    status: string\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    failures: any[]\n\n    outputLesson?: string | null\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    outputExercises?: any[]\n  }> {\n    let record = await payload.findByID({\n      collection: 'lesson-duplications',\n      id: recordId,\n      depth: 0,\n      overrideAccess: true,\n    })\n    const deadline = Date.now() + 30000\n    while ((record.status === 'running' || record.status === 'pending') && Date.now() < deadline) {\n      await new Promise((r) => setTimeout(r, 500))\n      record = await payload.findByID({\n        collection: 'lesson-duplications',\n        id: recordId,\n        depth: 0,\n        overrideAccess: true,\n      })\n    }\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    return record as any\n  }\n\n  it('5-exercise lesson with one forced failure ends in needs_review with failures recorded', async () => {\n    // Create pending duplication record\n    const record = await payload.create({\n      collection: 'lesson-duplications',\n      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n      overrideAccess: true,\n    })\n    cleanupDuplicationIds.push(record.id)\n\n    expect(record.status).toBe('pending')\n\n    // Run orchestrator (mocked runStrategy forces failure on exercise containing '-3')\n    try {\n      await runDuplicationOrchestrator(record.id, payload)\n    } catch {\n      // Orchestrator may throw if the mock is not properly applied;\n      // we still verify the DB record state below\n    }\n\n    // Poll until done\n    const finalRecord = await pollUntilDone(record.id)\n\n    // Final status must be needs_review (not succeeded, not failed)\n    expect(finalRecord.status).toBe('needs_review')\n\n    // At least one failure entry expected (exercise containing '-3' threw in runStrategy)\n    // Note: the exact count depends on exercise ID strings; we check ≥1 to be robust\n    expect(finalRecord.failures).toBeDefined()\n    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n    expect(finalRecord.failures[0].suggestedAction).toBe('skip')\n\n    // After orchestrator runs, outputLesson should be created\n    // Note: outputExercises remain empty in this test because the runStrategy mock\n    // bypasses processExercise (which calls createOutputExercise). Exercise creation\n    // is verified in lesson-duplication-review-resolve.int.spec.ts instead.\n    expect(finalRecord.outputLesson).toBeTruthy()\n  }, 180000)\n\n  it('orchestrator does not abort when one exercise fails — remaining exercises are processed', async () => {\n    // Create fresh pending record\n    const record = await payload.create({\n      collection: 'lesson-duplications',\n      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n      overrideAccess: true,\n    })\n    cleanupDuplicationIds.push(record.id)\n\n    // Run orchestrator; it may throw if the mock isn't applied (that's ok for this test)\n    try {\n      await runDuplicationOrchestrator(record.id, payload)\n    } catch {\n      // ignore\n    }\n\n    const finalRecord = await pollUntilDone(record.id)\n\n    // The orchestrator should reach needs_review (not 'failed'), meaning it processed\n    // exercises and collected failures rather than crashing completely.\n    // If the orchestrator crashed early, status would be 'failed' with 0 failures.\n    expect(finalRecord.status).toBe('needs_review')\n\n    // At least one failure means at least one exercise failed and the orchestrator\n    // continued processing other exercises (did not abort on first failure).\n    expect(finalRecord.failures).toBeDefined()\n    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n\n    // outputLesson should be created even when some exercises fail\n    expect(finalRecord.outputLesson).toBeTruthy()\n  }, 180000)\n})\n","numLines":415,"startLine":1,"totalLines":415}}}
