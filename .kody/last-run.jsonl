MINIMAX_API_KEY,\\n11\\t# ANTHROPIC_API_KEY). kody reads any *_API_KEY secret automatically via\\n12\\t# toJSON(secrets) — no need to list them here.\\n13\\t#\\n14\\t# Recommended: KODY_TOKEN secret — a fine-grained PAT or GitHub App token\\n15\\t# with `repo` + `read:org` + `workflow` scopes. Without it, kody's\\n16\\t# commits/PR-creation still work via github.token, but three things degrade:\\n17\\t#   1. PR body updates fail with \\\"token lacks read:org scope\\\" (cosmetic).\\n18\\t#   2. Pushes from kody won't trigger downstream workflows.\\n19\\t#   3. Any commit that modifies `.github/workflows/*` is REJECTED by\\n20\\t#      GitHub — the default GITHUB_TOKEN can't touch workflow files.\\n21\\t# Set KODY_TOKEN in repo Settings → Secrets → Actions.\\n22\\t\\n23\\t>>>>>>> origin/dev\\n24\\tname: kody\\n25\\t\\n26\\ton:\\n27\\t  workflow_dispatch:\\n28\\t    inputs:\\n29\\t      task_id:\\n30\\t        required: true\\n31\\t        type: string\\n32\\t      mode:\\n33\\t        type: string\\n34\\t        default: 'full'\\n35\\t      from_stage:\\n36\\t        type: string\\n37\\t        default: ''\\n38\\t      issue_number:\\n39\\t        type: string\\n40\\t        default: ''\\n41\\t      feedback:\\n42\\t        type: string\\n43\\t        default: ''\\n44\\t      dry_run:\\n45\\t        type: boolean\\n46\\t        default: false\\n47\\t      provider:\\n48\\t        type: string\\n49\\t        default: ''\\n50\\t      model:\\n51\\t        type: string\\n52\\t        default: ''\\n53\\t      auto_mode:\\n54\\t        type: boolean\\n55\\t        default: false\\n56\\t      finalize:\\n57\\t        type: boolean\\n58\\t        default: false\\n59\\t\\n60\\t  issue_comment:\\n61\\t    types: [created]\\n62\\t  pull_request:\\n63\\t    types: [closed]\\n64\\t  schedule:\\n65\\t    # Wakes every 30 minutes; kody fans out to whichever scheduled executables\\n66\\t    # (mission-scheduler, memorize, watch-stale-prs, …) match this tick.\\n67\\t    #\\n68\\t    # `memorize` writes to `.kody/vault/` and opens a daily PR. If your\\n69\\t    # `.gitignore` ignores `.kody/*`, add `!.kody/vault/` and `!.kody/vault/**`\\n70\\t    # so memorize's pages are tracked.\\n71\\t    - cron: '*/30 * * * *'\\n72\\t\\n73\\t<<<<<<< HEAD\\n74\\t  pull_request:\\n75\\t    types: [closed]\\n76\\t=======\\n77\\tjobs:\\n78\\t  run:\\n79\\t    if: ${{ github.event_name != 'pull_request' || github.event.pull_request.merged == true }}\\n80\\t    runs-on: ubuntu-latest\\n81\\t    timeout-minutes: 360\\n82\\t    concurrency:\\n83\\t      group: kody-${{ inputs.sessionId || inputs.issue_number || github.event.issue.number || github.sha }}\\n84\\t      cancel-in-progress: false\\n85\\t    permissions:\\n86\\t      issues: write\\n87\\t      pull-requests: write\\n88\\t      contents: write\\n89\\t      actions: read\\n90\\t    steps:\\n91\\t      - uses: actions/checkout@v4\\n92\\t        with:\\n93\\t          fetch-depth: 0\\n94\\t          ref: ${{ github.event.pull_request.base.ref || github.ref }}\\n95\\t          token: ${{ secrets.KODY_TOKEN || github.token }}\\n96\\t>>>>>>> origin/dev\\n97\\t\\n98\\t  pull_request_review:\\n99\\t    types: [submitted]\\n100\\t\\n101\\t  workflow_run:\\n102\\t    workflows: ['CI']\\n103\\t    types: [completed]\\n104\\t\\n105\\t  push:\\n106\\t    branches: [main, dev]\\n107\\t    paths: ['src/**', 'kody.config.json', 'package.json']\\n108\\t\\n109\\tconcurrency:\\n110\\t  group: kody-${{ github.event.inputs.task_id || github.event.issue.number || github.event.pull_request.number || github.event.workflow_run.id || github.sha }}\\n111\\t  cancel-in-progress: false\\n112\\t\\n113\\tpermissions:\\n114\\t  issues: write\\n115\\t  pull-requests: write\\n116\\t  contents: write\\n117\\t\\n118\\tjobs:\\n119\\t  # ─── Parse (issue_comment trigger only) ──────────────────────────────────────\\n120\\t  parse:\\n121\\t    if: >-\\n122\\t      github.event_name == 'issue_comment' &&\\n123\\t      github.event.issue.state != 'closed' &&\\n124\\t      github.event.comment.user.type != 'Bot' &&\\n125\\t      (contains(github.event.comment.body, '@kody') || contains(github.event.comment.body, '/kody'))\\n126\\t    runs-on: ubuntu-latest\\n127\\t    timeout-minutes: 5\\n128\\t    outputs:\\n129\\t      task_id: ${{ steps.parse.outputs.task_id }}\\n130\\t      mode: ${{ steps.parse.outputs.mode }}\\n131\\t      from_stage: ${{ steps.parse.outputs.from_stage }}\\n132\\t      issue_number: ${{ steps.parse.outputs.issue_number }}\\n133\\t      pr_number: ${{ steps.parse.outputs.pr_number }}\\n134\\t      feedback: ${{ steps.parse.outputs.feedback }}\\n135\\t      ci_run_id: ${{ steps.parse.outputs.ci_run_id }}\\n136\\t      ticket_id: ${{ steps.parse.outputs.ticket_id }}\\n137\\t      prd_file: ${{ steps.parse.outputs.prd_file }}\\n138\\t      dry_run: ${{ steps.parse.outputs.dry_run }}\\n139\\t      bump: ${{ steps.parse.outputs.bump }}\\n140\\t      finalize: ${{ steps.parse.outputs.finalize }}\\n141\\t      no_publish: ${{ steps.parse.outputs.no_publish }}\\n142\\t      no_notify: ${{ steps.parse.outputs.no_notify }}\\n143\\t      revert_target: ${{ steps.parse.outputs.revert_target }}\\n144\\t      valid: ${{ steps.parse.outputs.valid }}\\n145\\t    steps:\\n146\\t      - uses: actions/setup-node@v4\\n147\\t        with:\\n148\\t          node-version: 22\\n149\\t\\n150\\t      - name: Install Kody Engine\\n151\\t        run: npm install -g @kody-ade/engine\\n152\\t\\n153\\t<<<<<<< HEAD\\n154\\t      - name: Validate author\\n155\\t        id: safety\\n156\\t        run: |\\n157\\t          ALLOWED=\\\"COLLABORATOR MEMBER OWNER\\\"\\n158\\t          ASSOC=\\\"${{ github.event.comment.author_association }}\\\"\\n159\\t          if echo \\\"$ALLOWED\\\" | grep -qw \\\"$ASSOC\\\"; then\\n160\\t            echo \\\"valid=true\\\" >> $GITHUB_OUTPUT\\n161\\t          else\\n162\\t            echo \\\"valid=false\\\" >> $GITHUB_OUTPUT\\n163\\t            echo \\\"reason=Author association '$ASSOC' not allowed\\\" >> $GITHUB_OUTPUT\\n164\\t          fi\\n165\\t\\n166\\t      - name: Add reaction\\n167\\t        if: steps.safety.outputs.valid == 'true'\\n168\\t        uses: actions/github-script@v7\\n169\\t        continue-on-error: true\\n170\\t        with:\\n171\\t          script: |\\n172\\t            await github.rest.reactions.createForIssueComment({\\n173\\t              owner: context.repo.owner,\\n174\\t              repo: context.repo.repo,\\n175\\t              comment_id: context.payload.comment.id,\\n176\\t              content: 'eyes'\\n177\\t            })\\n178\\t\\n179\\t      - name: Parse inputs\\n180\\t        if: steps.safety.outputs.valid == 'true'\\n181\\t        id: parse\\n182\\t        env:\\n183\\t          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\\n184\\t          GH_REPO: ${{ github.repository }}\\n185\\t          COMMENT_BODY: ${{ github.event.comment.body }}\\n186\\t          ISSUE_NUMBER: ${{ github.event.issue.number }}\\n187\\t          ISSUE_IS_PR: ${{ github.event.issue.pull_request && 'true' || '' }}\\n188\\t          TRIGGER_TYPE: comment\\n189\\t          COMMENT_AUTHOR_ASSOC: ${{ github.event.comment.author_association }}\\n190\\t        run: kody-engine ci-parse\\n191\\t\\n192\\t  # ─── Orchestrate ─────────────────────────────────────────────────────────────\\n193\\t  orchestrate:\\n194\\t    # Only wait for parse on issue_comment; workflow_dispatch and pull_request_review bypass it\\n195\\t    if: >-\\n196\\t      github.event_name == 'workflow_dispatch' ||\\n197\\t      github.event_name == 'pull_request_review' ||\\n198\\t      (github.event_name == 'issue_comment' && needs.parse.outputs.valid == 'true')\\n199\\t    needs:\\n200\\t      - parse\\n201\\t    runs-on: ubuntu-latest\\n202\\t    timeout-minutes: 360\\n203\\t    services:\\n204\\t      mongodb:\\n205\\t        image: mongo:7\\n206\\t        ports:\\n207\\t          - 27017:27017\\n208\\t        options: >-\\n209\\t          --health-cmd \\\"mongosh --eval 'db.runCommand({ ping: 1 })'\\\"\\n210\\t          --health-interval 10s\\n211\\t          --health-timeout 5s\\n212\\t          --health-retries 5\\n213\\t    steps:\\n214\\t      - name: Generate App token\\n215\\t        id: app-token\\n216\\t        if: vars.KODY_APP_ID != ''\\n217\\t        uses: actions/create-github-app-token@v1\\n218\\t        with:\\n219\\t          app-id: ${{ vars.KODY_APP_ID }}\\n220\\t          private-key: ${{ secrets.APP_PRIVATE_KEY }}\\n221\\t          repositories: ${{ github.event.repository.name }}\\n222\\t\\n223\\t      - uses: actions/checkout@v4\\n224\\t        with:\\n225\\t          fetch-depth: 0\\n226\\t          persist-credentials: true\\n227\\t          token: ${{ secrets.GITHUB_TOKEN }}\\n228\\t\\n229\\t      - name: Checkout PR branch (for fix/rerun/review on PRs)\\n230\\t        if: github.event.issue.pull_request && (needs.parse.outputs.mode == 'fix' || needs.parse.outputs.mode == 'fix-ci' || needs.parse.outputs.mode == 'rerun' || needs.parse.outputs.mode == 'review' || needs.parse.outputs.mode == 'resolve')\\n231\\t        env:\\n232\\t          GH_TOKEN: ${{ steps.app-token.outputs.token || secrets.GITHUB_TOKEN }}\\n233\\t        run: |\\n234\\t          PR_NUM=\\\"${{ github.event.issue.number }}\\\"\\n235\\t          PR_BRANCH=$(gh pr view \\\"$PR_NUM\\\" --json headRefName -q '.headRefName')\\n236\\t          echo \\\"Checking out PR branch: $PR_BRANCH\\\"\\n237\\t          git checkout \\\"$PR_BRANCH\\\"\\n238\\t          git pull origin \\\"$PR_BRANCH\\\"\\n239\\t\\n240\\t      - uses: pnpm/action-setup@v4\\n241\\t        with:\\n242\\t          version: latest\\n243\\t      - uses: actions/setup-node@v4\\n244\\t        with:\\n245\\t          node-version: 22\\n246\\t          cache: pnpm\\n247\\t\\n248\\t      - run: pnpm install --frozen-lockfile\\n249\\t\\n250\\t      - name: Install Kody Engine\\n251\\t        run: npm install -g @kody-ade/engine\\n252\\t\\n253\\t      - name: Install Claude Code CLI\\n254\\t        run: npm install -g @anthropic-ai/claude-code\\n255\\t\\n256\\t      - name: Install LiteLLM proxy\\n257\\t        run: pip install 'litellm[proxy]' prisma && python -m prisma py fetch\\n258\\t\\n259\\t      - name: Get Playwright version\\n260\\t        run: echo \\\"version=$(pnpm exec playwright --version | head -1)\\\" >> $GITHUB_OUTPUT\\n261\\t\\n262\\t      - name: Cache Playwright browsers\\n263\\t        uses: actions/cache@v4\\n264\\t        with:\\n265\\t          path: ~/.cache/ms-playwright\\n266\\t          key: ${{ runner.os }}-playwright-${{ steps.playwright-version.outputs.version }}\\n267\\t\\n268\\t      - name: Install Playwright browsers\\n269\\t        run: pnpm exec playwright install --with-deps chromium\\n270\\t\\n271\\t      - name: Configure git\\n272\\t        run: |\\n273\\t          git config user.email \\\"41898282+github-actions[bot]@users.noreply.github.com\\\"\\n274\\t          git config user.name \\\"github-actions[bot]\\\"\\n275\\t\\n276\\t      - name: Export project secrets\\n277\\t        env:\\n278\\t          ALL_SECRETS: ${{ toJSON(secrets) }}\\n279\\t        run: |\\n280\\t          # Override MCP_ENABLED from secrets — Payload requires DEFAULT_TENANT_SLUG when MCP is on\\n281\\t          echo \\\"MCP_ENABLED=false\\\" >> $GITHUB_ENV\\n282\\t          echo \\\"$ALL_SECRETS\\\" | jq -r 'to_entries[] | select(.key | test(\\\"^(GITHUB_TOKEN)$\\\") | not) | @json' | while IFS= read -r entry; do\\n283\\t            KEY=$(echo \\\"$entry\\\" | jq -r '.key')\\n284\\t            VALUE=$(echo \\\"$entry\\\" | jq -r '.value')\\n285\\t            DELIM=\\\"KODY_EOF_${KEY}\\\"\\n286\\t            echo \\\"${KEY}<<${DELIM}\\\" >> $GITHUB_ENV\\n287\\t            echo \\\"${VALUE}\\\" >> $GITHUB_ENV\\n288\\t            echo \\\"${DELIM}\\\" >> $GITHUB_ENV\\n289\\t          done\\n290\\t\\n291\\t      - name: Warm up Next.js build cache\\n292\\t        run: NODE_OPTIONS='--max-old-space-size=6144' npx next build\\n293\\t        timeout-minutes: 20\\n294\\t\\n295\\t      - name: Run Kody pipeline\\n296\\t        env:\\n297\\t          GH_TOKEN: ${{ secrets.PROJECT_TOKEN || secrets.GITHUB_TOKEN }}\\n298\\t          TASK_ID: ${{ github.event.inputs.task_id || needs.parse.outputs.task_id }}\\n299\\t          MODE: ${{ github.event.inputs.mode || needs.parse.outputs.mode || 'full' }}\\n300\\t          FROM_STAGE: ${{ github.event.inputs.from_stage || needs.parse.outputs.from_stage }}\\n301\\t          ISSUE_NUMBER: ${{ github.event.inputs.issue_number || needs.parse.outputs.issue_number }}\\n302\\t          PR_NUMBER: ${{ needs.parse.outputs.pr_number }}\\n303\\t          FEEDBACK: ${{ github.event.inputs.feedback || needs.parse.outputs.feedback }}\\n304\\t          COMPLEXITY: ${{ needs.parse.outputs.complexity }}\\n305\\t          CI_RUN_ID: ${{ needs.parse.outputs.ci_run_id }}\\n306\\t          TICKET_ID: ${{ needs.parse.outputs.ticket_id }}\\n307\\t          PRD_FILE: ${{ needs.parse.outputs.prd_file }}\\n308\\t          DRY_RUN: ${{ github.event.inputs.dry_run || needs.parse.outputs.dry_run || 'false' }}\\n309\\t          AUTO_MODE: ${{ github.event.inputs.auto_mode }}\\n310\\t          BUMP: ${{ needs.parse.outputs.bump }}\\n311\\t          FINALIZE: ${{ github.event.inputs.finalize || needs.parse.outputs.finalize }}\\n312\\t          NO_PUBLISH: ${{ needs.parse.outputs.no_publish }}\\n313\\t          NO_NOTIFY: ${{ needs.parse.outputs.no_notify }}\\n314\\t          REVERT_TARGET: ${{ needs.parse.outputs.revert_target }}\\n315\\t          RUN-URL: ${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}\\n316\\t        run: |\\n317\\t          if [ \\\"$MODE\\\" = \\\"release\\\" ]; then\\n318\\t            echo \\\"Running release...\\\"\\n319\\t            ARGS=\\\"\\\"\\n320\\t            [ \\\"$FINALIZE\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --finalize\\\"\\n321\\t            [ -n \\\"$BUMP\\\" ] && ARGS=\\\"$ARGS --bump=$BUMP\\\"\\n322\\t            [ \\\"$NO_PUBLISH\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --no-publish\\\"\\n323\\t            [ \\\"$NO_NOTIFY\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --no-notify\\\"\\n324\\t            [ \\\"$DRY_RUN\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --dry-run\\\"\\n325\\t            [ -n \\\"$ISSUE_NUMBER\\\" ] && ARGS=\\\"$ARGS --issue-number $ISSUE_NUMBER\\\"\\n326\\t            kody-engine release $ARGS\\n327\\t          elif [ \\\"$MODE\\\" = \\\"revert\\\" ]; then\\n328\\t            echo \\\"Running revert...\\\"\\n329\\t            ARGS=\\\"\\\"\\n330\\t            [ -n \\\"$REVERT_TARGET\\\" ] && ARGS=\\\"$ARGS --target $REVERT_TARGET\\\"\\n331\\t            [ -n \\\"$ISSUE_NUMBER\\\" ] && ARGS=\\\"$ARGS --issue-number $ISSUE_NUMBER\\\"\\n332\\t            [ \\\"$DRY_RUN\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --dry-run\\\"\\n333\\t            kody-engine revert $ARGS\\n334\\t          elif [ \\\"$MODE\\\" = \\\"bootstrap\\\" ]; then\\n335\\t            echo \\\"Running bootstrap...\\\"\\n336\\t            kody-engine bootstrap\\n337\\t          elif [ \\\"$MODE\\\" = \\\"taskify\\\" ]; then\\n338\\t            echo \\\"Running taskify...\\\"\\n339\\t            ARGS=\\\"\\\"\\n340\\t            [ -n \\\"$TICKET_ID\\\" ] && ARGS=\\\"$ARGS --ticket $TICKET_ID\\\"\\n341\\t            [ -n \\\"$PRD_FILE\\\" ] && ARGS=\\\"$ARGS --file $PRD_FILE\\\"\\n342\\t            [ -n \\\"$ISSUE_NUMBER\\\" ] && ARGS=\\\"$ARGS --issue-number $ISSUE_NUMBER\\\"\\n343\\t            [ -n \\\"$TASK_ID\\\" ] && ARGS=\\\"$ARGS --task-id $TASK_ID\\\"\\n344\\t            kody-engine taskify $ARGS\\n345\\t          else\\n346\\t            CMD=\\\"run\\\"\\n347\\t            [ \\\"$MODE\\\" = \\\"rerun\\\" ] && CMD=\\\"rerun\\\"\\n348\\t            [ \\\"$MODE\\\" = \\\"fix\\\" ] && CMD=\\\"fix\\\"\\n349\\t            [ \\\"$MODE\\\" = \\\"fix-ci\\\" ] && CMD=\\\"fix-ci\\\"\\n350\\t            [ \\\"$MODE\\\" = \\\"review\\\" ] && CMD=\\\"review\\\"\\n351\\t            [ \\\"$MODE\\\" = \\\"resolve\\\" ] && CMD=\\\"resolve\\\"\\n352\\t            [ \\\"$MODE\\\" = \\\"status\\\" ] && CMD=\\\"status\\\"\\n353\\t            [ \\\"$MODE\\\" = \\\"hotfix\\\" ] && CMD=\\\"hotfix\\\"\\n354\\t            ARGS=\\\"--issue-number $ISSUE_NUMBER\\\"\\n355\\t            [ -n \\\"$TASK_ID\\\" ] && ARGS=\\\"$ARGS --task-id $TASK_ID\\\"\\n356\\t            [ -n \\\"$PR_NUMBER\\\" ] && ARGS=\\\"$ARGS --pr-number $PR_NUMBER\\\"\\n357\\t            [ -n \\\"$FROM_STAGE\\\" ] && ARGS=\\\"$ARGS --from $FROM_STAGE\\\"\\n358\\t            [ -n \\\"$COMPLEXITY\\\" ] && ARGS=\\\"$ARGS --complexity $COMPLEXITY\\\"\\n359\\t            # FEEDBACK is also passed via env var (avoids shell escaping issues)\\n360\\t            [ -n \\\"$FEEDBACK\\\" ] && ARGS=\\\"$ARGS --feedback \\\\\\\"$FEEDBACK\\\\\\\"\\\"\\n361\\t            [ \\\"$DRY_RUN\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --dry-run\\\"\\n362\\t            [ \\\"$AUTO_MODE\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --auto-mode\\\"\\n363\\t            kody-engine $CMD $ARGS\\n364\\t          fi\\n365\\t\\n366\\t      - name: Pipeline summary\\n367\\t        if: always()\\n368\\t        run: |\\n369\\t          TASK_ID=\\\"${{ github.event.inputs.task_id || needs.parse.outputs.task_id }}\\\"\\n370\\t          STATUS_FILE=\\\".kody/tasks/${TASK_ID}/status.json\\\"\\n371\\t          if [ -f \\\"$STATUS_FILE\\\" ]; then\\n372\\t            STATE=$(jq -r '.state' \\\"$STATUS_FILE\\\")\\n373\\t            ICON=\\\"❌\\\"\\n374\\t            [ \\\"$STATE\\\" = \\\"completed\\\" ] && ICON=\\\"✅\\\"\\n375\\t            echo \\\"## ${ICON} Kody Pipeline: \\\\`${TASK_ID}\\\\`\\\" >> $GITHUB_STEP_SUMMARY\\n376\\t            echo \\\"\\\" >> $GITHUB_STEP_SUMMARY\\n377\\t            echo \\\"**Status:** ${STATE}\\\" >> $GITHUB_STEP_SUMMARY\\n378\\t            echo \\\"\\\" >> $GITHUB_STEP_SUMMARY\\n379\\t            echo \\\"| Stage | State |\\\" >> $GITHUB_STEP_SUMMARY\\n380\\t            echo \\\"|-------|-------|\\\" >> $GITHUB_STEP_SUMMARY\\n381\\t            for stage in taskify plan build verify review review-fix ship; do\\n382\\t              SSTATE=$(jq -r \\\".stages[\\\\\\\"$stage\\\\\\\"].state // \\\\\\\"—\\\\\\\"\\\" \\\"$STATUS_FILE\\\")\\n383\\t              case \\\"$SSTATE\\\" in\\n384\\t                completed) SICON=\\\"✅\\\" ;;\\n385\\t                failed)    SICON=\\\"❌\\\" ;;\\n386\\t                timeout)   SICON=\\\"⏱\\\" ;;\\n387\\t                running)   SICON=\\\"▶️\\\" ;;\\n388\\t                *)         SICON=\\\"○\\\" ;;\\n389\\t              esac\\n390\\t              echo \\\"| ${stage} | ${SICON} ${SSTATE} |\\\" >> $GITHUB_STEP_SUMMARY\\n391\\t            done\\n392\\t          fi\\n393\\t\\n394\\t      - name: Upload artifacts\\n395\\t        if: always()\\n396\\t        uses: actions/upload-artifact@v4\\n397\\t        continue-on-error: true\\n398\\t        with:\\n399\\t          name: kody-tasks-${{ github.event.inputs.task_id || needs.parse.outputs.task_id }}\\n400\\t          path: .kody/tasks/\\n401\\t          retention-days: 3\\n402\\t\\n403\\t  # ─── Close Issue on PR Merge ────────────────────────────────────────────────\\n404\\t  close-issue-on-merge:\\n405\\t    if: >-\\n406\\t      github.event_name == 'pull_request' &&\\n407\\t      github.event.pull_request.merged == true\\n408\\t    runs-on: ubuntu-latest\\n409\\t    permissions:\\n410\\t      issues: write\\n411\\t    steps:\\n412\\t      - name: Generate App token\\n413\\t        id: app-token\\n414\\t        if: vars.KODY_APP_ID != ''\\n415\\t        uses: actions/create-github-app-token@v1\\n416\\t        with:\\n417\\t          app-id: ${{ vars.KODY_APP_ID }}\\n418\\t          private-key: ${{ secrets.APP_PRIVATE_KEY }}\\n419\\t          repositories: ${{ github.event.repository.name }}\\n420\\t\\n421\\t      - name: Close linked issue\\n422\\t        uses: actions/github-script@v7\\n423\\t        with:\\n424\\t          github-token: ${{ steps.app-token.outputs.token || secrets.GITHUB_TOKEN }}\\n425\\t          script: |\\n426\\t            // Extract issue number from branch name (e.g. \\\"42-feature-name\\\")\\n427\\t            const branch = context.payload.pull_request.head.ref;\\n428\\t            const match = branch.match(/^(\\\\d+)-/);\\n429\\t            if (!match) return;\\n430\\t            const issueNumber = parseInt(match[1], 10);\\n431\\t\\n432\\t            // Verify the issue exists and is open\\n433\\t            try {\\n434\\t              const { data: issue } = await github.rest.issues.get({\\n435\\t                owner: context.repo.owner,\\n436\\t                repo: context.repo.repo,\\n437\\t                issue_number: issueNumber,\\n438\\t              });\\n439\\t              if (issue.state === 'closed') return;\\n440\\t              if (issue.pull_request) return; // Skip if it's a PR, not an issue\\n441\\t\\n442\\t              await github.rest.issues.update({\\n443\\t                owner: context.repo.owner,\\n444\\t                repo: context.repo.repo,\\n445\\t                issue_number: issueNumber,\\n446\\t                state: 'closed',\\n447\\t                state_reason: 'completed',\\n448\\t              });\\n449\\t              core.info(`Closed issue #${issueNumber} after PR #${context.payload.pull_request.number} was merged`);\\n450\\t            } catch (e) {\\n451\\t              core.warning(`Could not close issue #${issueNumber}: ${e.message}`);\\n452\\t            }\\n453\\t\\n454\\t  # ─── Error Notifications ─────────────────────────────────────────────────────\\n455\\t  notify-parse-error:\\n456\\t    if: >-\\n457\\t      github.event_name == 'issue_comment' &&\\n458\\t      needs.parse.outputs.valid != 'true' &&\\n459\\t      (contains(github.event.comment.body, '@kody') || contains(github.event.comment.body, '/kody'))\\n460\\t    needs: [parse]\\n461\\t    runs-on: ubuntu-latest\\n462\\t    steps:\\n463\\t      - uses: actions/github-script@v7\\n464\\t        with:\\n465\\t          script: |\\n466\\t            await github.rest.issues.createComment({\\n467\\t              owner: context.repo.owner,\\n468\\t              repo: context.repo.repo,\\n469\\t              issue_number: context.issue.number,\\n470\\t              body: '❌ Failed to parse command.\\\\n\\\\nUsage: `@kody [full|rerun|fix|fix-ci|review|resolve|status] [--from <stage>] [--feedback \\\"<text>\\\"]`'\\n471\\t            })\\n472\\t\\n473\\t  notify-orchestrate-error:\\n474\\t    if: failure() && needs.orchestrate.result == 'failure'\\n475\\t    needs: [orchestrate]\\n476\\t    runs-on: ubuntu-latest\\n477\\t    steps:\\n478\\t      - uses: actions/github-script@v7\\n479\\t        with:\\n480\\t          script: |\\n481\\t            const issueNumber = Number('${{ github.event.inputs.issue_number || needs.parse.outputs.issue_number || 0 }}');\\n482\\t            if (issueNumber > 0) {\\n483\\t              await github.rest.issues.createComment({\\n484\\t                owner: context.repo.owner,\\n485\\t                repo: context.repo.repo,\\n486\\t                issue_number: issueNumber,\\n487\\t                body: `❌ Pipeline failed. [View logs](${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId})`\\n488\\t              });\\n489\\t            }\\n490\\t\\n491\\t  # ─── Fix-CI Auto-trigger (workflow_run trigger) ─────────────────────────────\\n492\\t  fix-ci-trigger:\\n493\\t    if: >-\\n494\\t      github.event_name == 'workflow_run' &&\\n495\\t      github.event.workflow_run.conclusion == 'failure' &&\\n496\\t      github.event.workflow_run.event == 'pull_request' &&\\n497\\t      github.event.workflow_run.pull_requests[0]\\n498\\t    runs-on: ubuntu-latest\\n499\\t    timeout-minutes: 5\\n500\\t    permissions:\\n501\\t      issues: write\\n502\\t      pull-requests: write\\n503\\t    steps:\\n504\\t      - name: Check loop guard and post fix-ci comment\\n505\\t        uses: actions/github-script@v7\\n506\\t        with:\\n507\\t          script: |\\n508\\t            const pr = context.payload.workflow_run.pull_requests[0];\\n509\\t            const prNumber = pr.number;\\n510\\t\\n511\\t            // Check recent comments for existing fix-ci attempt (last 24h)\\n512\\t            const comments = await github.rest.issues.listComments({\\n513\\t              owner: context.repo.owner,\\n514\\t              repo: context.repo.repo,\\n515\\t              issue_number: prNumber,\\n516\\t              per_page: 30,\\n517\\t            });\\n518\\t\\n519\\t            const oneDayAgo = new Date(Date.now() - 24 * 60 * 60 * 1000);\\n520\\t            const recentFixCi = comments.data.filter(\\n521\\t              (c) => c.body.includes('@kody fix-ci') && new Date(c.created_at) > oneDayAgo\\n522\\t            );\\n523\\t\\n524\\t            if (recentFixCi.length >= 1) {\\n525\\t              core.info('Loop guard: @kody fix-ci already commented in last 24h, skipping');\\n526\\t              return;\\n527\\t            }\\n528\\t\\n529\\t            // Check if last commit was from a bot (kody's previous fix attempt)\\n530\\t            const commits = await github.rest.pulls.listCommits({\\n531\\t              owner: context.repo.owner,\\n532\\t              repo: context.repo.repo,\\n533\\t              pull_number: prNumber,\\n534\\t              per_page: 1,\\n535\\t            });\\n536\\t            const lastAuthor = commits.data[commits.data.length - 1]?.commit?.author?.name;\\n537\\t            if (lastAuthor === 'github-actions[bot]' || lastAuthor === 'kody[bot]') {\\n538\\t              core.info('Loop guard: last commit from bot, skipping');\\n539\\t              return;\\n540\\t            }\\n541\\t\\n542\\t            // Post fix-ci comment\\n543\\t            const runId = context.payload.workflow_run.id;\\n544\\t            const runUrl = `${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${runId}`;\\n545\\t            await github.rest.issues.createComment({\\n546\\t              owner: context.repo.owner,\\n547\\t              repo: context.repo.repo,\\n548\\t              issue_number: prNumber,\\n549\\t              body: `@kody fix-ci\\\\nCI failed: [View logs](${runUrl})\\\\nRun ID: ${runId}`,\\n550\\t            });\\n551\\t            core.info(`Posted @kody fix-ci on PR #${prNumber} for run ${runId}`);\\n552\\t=======\\n553\\t      - uses: actions/setup-python@v5\\n554\\t        with:\\n555\\t          python-version: '3.12'\\n556\\t          cache: 'pip'\\n557\\t          cache-dependency-path: .kody-pip-requirements.txt\\n558\\t\\n559\\t      # Pre-pull the MongoDB image used by scripts/release-e2e-gate.ts\\n560\\t      # (invoked during `@kody release --finalize`). The pull happens in its\\n561\\t      # own GitHub Actions step, outside kody's internal per-step timeout,\\n562\\t      # so the gate starts with the image already in the local Docker cache.\\n563\\t      - name: Warm Docker image cache for release e2e gate\\n564\\t        run: docker pull mongo:6\\n565\\t\\n566\\t      - env:\\n567\\t          ALL_SECRETS: ${{ toJSON(secrets) }}\\n568\\t          SESSION_ID: ${{ inputs.sessionId }}\\n569\\t          INIT_MESSAGE: ${{ inputs.message }}\\n570\\t          MODEL: ${{ inputs.model }}\\n571\\t          DASHBOARD_URL: ${{ inputs.dashboardUrl }}\\n572\\t        run: npx -y -p @kody-ade/kody-engine@latest kody\\n573\\t>>>>>>> origin/dev\\n574\\t\"}]},\"parent_tool_use_id\":null,\"session_id\":\"01102eb0-252a-47dc-9009-d0d0ba855c49\",\"uuid\":\"576864d3-a2ca-4c6c-8402-bb05a28d7fba\",\"timestamp\":\"2026-04-29T13:13:58.469Z\",\"tool_use_result\":{\"type\":\"text\",\"file\":{\"filePath\":\"/home/runner/work/A-Guy/A-Guy/.github/workflows/kody.yml\",\"content\":\"<<<<<<< HEAD\\n=======\\n# Drop this file at .github/workflows/kody.yml in your repo.\\n#\\n# Triggers forward every relevant event to `kody`; the engine decides what\\n# (if anything) to do. The job runs `npx kody` — no shell branching, no\\n# routing logic in YAML. All orchestration lives in the kody npm package;\\n# future capabilities ship via `npm publish`, not by editing this file.\\n#\\n# Required repo secrets: at least one model provider key (e.g. MINIMAX_API_KEY,\\n# ANTHROPIC_API_KEY). kody reads any *_API_KEY secret automatically via\\n# toJSON(secrets) — no need to list them here.\\n#\\n# Recommended: KODY_TOKEN secret — a fine-grained PAT or GitHub App token\\n# with `repo` + `read:org` + `workflow` scopes. Without it, kody's\\n# commits/PR-creation still work via github.token, but three things degrade:\\n#   1. PR body updates fail with \\\"token lacks read:org scope\\\" (cosmetic).\\n#   2. Pushes from kody won't trigger downstream workflows.\\n#   3. Any commit that modifies `.github/workflows/*` is REJECTED by\\n#      GitHub — the default GITHUB_TOKEN can't touch workflow files.\\n# Set KODY_TOKEN in repo Settings → Secrets → Actions.\\n\\n>>>>>>> origin/dev\\nname: kody\\n\\non:\\n  workflow_dispatch:\\n    inputs:\\n      task_id:\\n        required: true\\n        type: string\\n      mode:\\n        type: string\\n        default: 'full'\\n      from_stage:\\n        type: string\\n        default: ''\\n      issue_number:\\n        type: string\\n        default: ''\\n      feedback:\\n        type: string\\n        default: ''\\n      dry_run:\\n        type: boolean\\n        default: false\\n      provider:\\n        type: string\\n        default: ''\\n      model:\\n        type: string\\n        default: ''\\n      auto_mode:\\n        type: boolean\\n        default: false\\n      finalize:\\n        type: boolean\\n        default: false\\n\\n  issue_comment:\\n    types: [created]\\n  pull_request:\\n    types: [closed]\\n  schedule:\\n    # Wakes every 30 minutes; kody fans out to whichever scheduled executables\\n    # (mission-scheduler, memorize, watch-stale-prs, …) match this tick.\\n    #\\n    # `memorize` writes to `.kody/vault/` and opens a daily PR. If your\\n    # `.gitignore` ignores `.kody/*`, add `!.kody/vault/` and `!.kody/vault/**`\\n    # so memorize's pages are tracked.\\n    - cron: '*/30 * * * *'\\n\\n<<<<<<< HEAD\\n  pull_request:\\n    types: [closed]\\n=======\\njobs:\\n  run:\\n    if: ${{ github.event_name != 'pull_request' || github.event.pull_request.merged == true }}\\n    runs-on: ubuntu-latest\\n    timeout-minutes: 360\\n    concurrency:\\n      group: kody-${{ inputs.sessionId || inputs.issue_number || github.event.issue.number || github.sha }}\\n      cancel-in-progress: false\\n    permissions:\\n      issues: write\\n      pull-requests: write\\n      contents: write\\n      actions: read\\n    steps:\\n      - uses: actions/checkout@v4\\n        with:\\n          fetch-depth: 0\\n          ref: ${{ github.event.pull_request.base.ref || github.ref }}\\n          token: ${{ secrets.KODY_TOKEN || github.token }}\\n>>>>>>> origin/dev\\n\\n  pull_request_review:\\n    types: [submitted]\\n\\n  workflow_run:\\n    workflows: ['CI']\\n    types: [completed]\\n\\n  push:\\n    branches: [main, dev]\\n    paths: ['src/**', 'kody.config.json', 'package.json']\\n\\nconcurrency:\\n  group: kody-${{ github.event.inputs.task_id || github.event.issue.number || github.event.pull_request.number || github.event.workflow_run.id || github.sha }}\\n  cancel-in-progress: false\\n\\npermissions:\\n  issues: write\\n  pull-requests: write\\n  contents: write\\n\\njobs:\\n  # ─── Parse (issue_comment trigger only) ──────────────────────────────────────\\n  parse:\\n    if: >-\\n      github.event_name == 'issue_comment' &&\\n      github.event.issue.state != 'closed' &&\\n      github.event.comment.user.type != 'Bot' &&\\n      (contains(github.event.comment.body, '@kody') || contains(github.event.comment.body, '/kody'))\\n    runs-on: ubuntu-latest\\n    timeout-minutes: 5\\n    outputs:\\n      task_id: ${{ steps.parse.outputs.task_id }}\\n      mode: ${{ steps.parse.outputs.mode }}\\n      from_stage: ${{ steps.parse.outputs.from_stage }}\\n      issue_number: ${{ steps.parse.outputs.issue_number }}\\n      pr_number: ${{ steps.parse.outputs.pr_number }}\\n      feedback: ${{ steps.parse.outputs.feedback }}\\n      ci_run_id: ${{ steps.parse.outputs.ci_run_id }}\\n      ticket_id: ${{ steps.parse.outputs.ticket_id }}\\n      prd_file: ${{ steps.parse.outputs.prd_file }}\\n      dry_run: ${{ steps.parse.outputs.dry_run }}\\n      bump: ${{ steps.parse.outputs.bump }}\\n      finalize: ${{ steps.parse.outputs.finalize }}\\n      no_publish: ${{ steps.parse.outputs.no_publish }}\\n      no_notify: ${{ steps.parse.outputs.no_notify }}\\n      revert_target: ${{ steps.parse.outputs.revert_target }}\\n      valid: ${{ steps.parse.outputs.valid }}\\n    steps:\\n      - uses: actions/setup-node@v4\\n        with:\\n          node-version: 22\\n\\n      - name: Install Kody Engine\\n        run: npm install -g @kody-ade/engine\\n\\n<<<<<<< HEAD\\n      - name: Validate author\\n        id: safety\\n        run: |\\n          ALLOWED=\\\"COLLABORATOR MEMBER OWNER\\\"\\n          ASSOC=\\\"${{ github.event.comment.author_association }}\\\"\\n          if echo \\\"$ALLOWED\\\" | grep -qw \\\"$ASSOC\\\"; then\\n            echo \\\"valid=true\\\" >> $GITHUB_OUTPUT\\n          else\\n            echo \\\"valid=false\\\" >> $GITHUB_OUTPUT\\n            echo \\\"reason=Author association '$ASSOC' not allowed\\\" >> $GITHUB_OUTPUT\\n          fi\\n\\n      - name: Add reaction\\n        if: steps.safety.outputs.valid == 'true'\\n        uses: actions/github-script@v7\\n        continue-on-error: true\\n        with:\\n          script: |\\n            await github.rest.reactions.createForIssueComment({\\n              owner: context.repo.owner,\\n              repo: context.repo.repo,\\n              comment_id: context.payload.comment.id,\\n              content: 'eyes'\\n            })\\n\\n      - name: Parse inputs\\n        if: steps.safety.outputs.valid == 'true'\\n        id: parse\\n        env:\\n          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\\n          GH_REPO: ${{ github.repository }}\\n          COMMENT_BODY: ${{ github.event.comment.body }}\\n          ISSUE_NUMBER: ${{ github.event.issue.number }}\\n          ISSUE_IS_PR: ${{ github.event.issue.pull_request && 'true' || '' }}\\n          TRIGGER_TYPE: comment\\n          COMMENT_AUTHOR_ASSOC: ${{ github.event.comment.author_association }}\\n        run: kody-engine ci-parse\\n\\n  # ─── Orchestrate ─────────────────────────────────────────────────────────────\\n  orchestrate:\\n    # Only wait for parse on issue_comment; workflow_dispatch and pull_request_review bypass it\\n    if: >-\\n      github.event_name == 'workflow_dispatch' ||\\n      github.event_name == 'pull_request_review' ||\\n      (github.event_name == 'issue_comment' && needs.parse.outputs.valid == 'true')\\n    needs:\\n      - parse\\n    runs-on: ubuntu-latest\\n    timeout-minutes: 360\\n    services:\\n      mongodb:\\n        image: mongo:7\\n        ports:\\n          - 27017:27017\\n        options: >-\\n          --health-cmd \\\"mongosh --eval 'db.runCommand({ ping: 1 })'\\\"\\n          --health-interval 10s\\n          --health-timeout 5s\\n          --health-retries 5\\n    steps:\\n      - name: Generate App token\\n        id: app-token\\n        if: vars.KODY_APP_ID != ''\\n        uses: actions/create-github-app-token@v1\\n        with:\\n          app-id: ${{ vars.KODY_APP_ID }}\\n          private-key: ${{ secrets.APP_PRIVATE_KEY }}\\n          repositories: ${{ github.event.repository.name }}\\n\\n      - uses: actions/checkout@v4\\n        with:\\n          fetch-depth: 0\\n          persist-credentials: true\\n          token: ${{ secrets.GITHUB_TOKEN }}\\n\\n      - name: Checkout PR branch (for fix/rerun/review on PRs)\\n        if: github.event.issue.pull_request && (needs.parse.outputs.mode == 'fix' || needs.parse.outputs.mode == 'fix-ci' || needs.parse.outputs.mode == 'rerun' || needs.parse.outputs.mode == 'review' || needs.parse.outputs.mode == 'resolve')\\n        env:\\n          GH_TOKEN: ${{ steps.app-token.outputs.token || secrets.GITHUB_TOKEN }}\\n        run: |\\n          PR_NUM=\\\"${{ github.event.issue.number }}\\\"\\n          PR_BRANCH=$(gh pr view \\\"$PR_NUM\\\" --json headRefName -q '.headRefName')\\n          echo \\\"Checking out PR branch: $PR_BRANCH\\\"\\n          git checkout \\\"$PR_BRANCH\\\"\\n          git pull origin \\\"$PR_BRANCH\\\"\\n\\n      - uses: pnpm/action-setup@v4\\n        with:\\n          version: latest\\n      - uses: actions/setup-node@v4\\n        with:\\n          node-version: 22\\n          cache: pnpm\\n\\n      - run: pnpm install --frozen-lockfile\\n\\n      - name: Install Kody Engine\\n        run: npm install -g @kody-ade/engine\\n\\n      - name: Install Claude Code CLI\\n        run: npm install -g @anthropic-ai/claude-code\\n\\n      - name: Install LiteLLM proxy\\n        run: pip install 'litellm[proxy]' prisma && python -m prisma py fetch\\n\\n      - name: Get Playwright version\\n        run: echo \\\"version=$(pnpm exec playwright --version | head -1)\\\" >> $GITHUB_OUTPUT\\n\\n      - name: Cache Playwright browsers\\n        uses: actions/cache@v4\\n        with:\\n          path: ~/.cache/ms-playwright\\n          key: ${{ runner.os }}-playwright-${{ steps.playwright-version.outputs.version }}\\n\\n      - name: Install Playwright browsers\\n        run: pnpm exec playwright install --with-deps chromium\\n\\n      - name: Configure git\\n        run: |\\n          git config user.email \\\"41898282+github-actions[bot]@users.noreply.github.com\\\"\\n          git config user.name \\\"github-actions[bot]\\\"\\n\\n      - name: Export project secrets\\n        env:\\n          ALL_SECRETS: ${{ toJSON(secrets) }}\\n        run: |\\n          # Override MCP_ENABLED from secrets — Payload requires DEFAULT_TENANT_SLUG when MCP is on\\n          echo \\\"MCP_ENABLED=false\\\" >> $GITHUB_ENV\\n          echo \\\"$ALL_SECRETS\\\" | jq -r 'to_entries[] | select(.key | test(\\\"^(GITHUB_TOKEN)$\\\") | not) | @json' | while IFS= read -r entry; do\\n            KEY=$(echo \\\"$entry\\\" | jq -r '.key')\\n            VALUE=$(echo \\\"$entry\\\" | jq -r '.value')\\n            DELIM=\\\"KODY_EOF_${KEY}\\\"\\n            echo \\\"${KEY}<<${DELIM}\\\" >> $GITHUB_ENV\\n            echo \\\"${VALUE}\\\" >> $GITHUB_ENV\\n            echo \\\"${DELIM}\\\" >> $GITHUB_ENV\\n          done\\n\\n      - name: Warm up Next.js build cache\\n        run: NODE_OPTIONS='--max-old-space-size=6144' npx next build\\n        timeout-minutes: 20\\n\\n      - name: Run Kody pipeline\\n        env:\\n          GH_TOKEN: ${{ secrets.PROJECT_TOKEN || secrets.GITHUB_TOKEN }}\\n          TASK_ID: ${{ github.event.inputs.task_id || needs.parse.outputs.task_id }}\\n          MODE: ${{ github.event.inputs.mode || needs.parse.outputs.mode || 'full' }}\\n          FROM_STAGE: ${{ github.event.inputs.from_stage || needs.parse.outputs.from_stage }}\\n          ISSUE_NUMBER: ${{ github.event.inputs.issue_number || needs.parse.outputs.issue_number }}\\n          PR_NUMBER: ${{ needs.parse.outputs.pr_number }}\\n          FEEDBACK: ${{ github.event.inputs.feedback || needs.parse.outputs.feedback }}\\n          COMPLEXITY: ${{ needs.parse.outputs.complexity }}\\n          CI_RUN_ID: ${{ needs.parse.outputs.ci_run_id }}\\n          TICKET_ID: ${{ needs.parse.outputs.ticket_id }}\\n          PRD_FILE: ${{ needs.parse.outputs.prd_file }}\\n          DRY_RUN: ${{ github.event.inputs.dry_run || needs.parse.outputs.dry_run || 'false' }}\\n          AUTO_MODE: ${{ github.event.inputs.auto_mode }}\\n          BUMP: ${{ needs.parse.outputs.bump }}\\n          FINALIZE: ${{ github.event.inputs.finalize || needs.parse.outputs.finalize }}\\n          NO_PUBLISH: ${{ needs.parse.outputs.no_publish }}\\n          NO_NOTIFY: ${{ needs.parse.outputs.no_notify }}\\n          REVERT_TARGET: ${{ needs.parse.outputs.revert_target }}\\n          RUN-URL: ${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}\\n        run: |\\n          if [ \\\"$MODE\\\" = \\\"release\\\" ]; then\\n            echo \\\"Running release...\\\"\\n            ARGS=\\\"\\\"\\n            [ \\\"$FINALIZE\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --finalize\\\"\\n            [ -n \\\"$BUMP\\\" ] && ARGS=\\\"$ARGS --bump=$BUMP\\\"\\n            [ \\\"$NO_PUBLISH\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --no-publish\\\"\\n            [ \\\"$NO_NOTIFY\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --no-notify\\\"\\n            [ \\\"$DRY_RUN\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --dry-run\\\"\\n            [ -n \\\"$ISSUE_NUMBER\\\" ] && ARGS=\\\"$ARGS --issue-number $ISSUE_NUMBER\\\"\\n            kody-engine release $ARGS\\n          elif [ \\\"$MODE\\\" = \\\"revert\\\" ]; then\\n            echo \\\"Running revert...\\\"\\n            ARGS=\\\"\\\"\\n            [ -n \\\"$REVERT_TARGET\\\" ] && ARGS=\\\"$ARGS --target $REVERT_TARGET\\\"\\n            [ -n \\\"$ISSUE_NUMBER\\\" ] && ARGS=\\\"$ARGS --issue-number $ISSUE_NUMBER\\\"\\n            [ \\\"$DRY_RUN\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --dry-run\\\"\\n            kody-engine revert $ARGS\\n          elif [ \\\"$MODE\\\" = \\\"bootstrap\\\" ]; then\\n            echo \\\"Running bootstrap...\\\"\\n            kody-engine bootstrap\\n          elif [ \\\"$MODE\\\" = \\\"taskify\\\" ]; then\\n            echo \\\"Running taskify...\\\"\\n            ARGS=\\\"\\\"\\n            [ -n \\\"$TICKET_ID\\\" ] && ARGS=\\\"$ARGS --ticket $TICKET_ID\\\"\\n            [ -n \\\"$PRD_FILE\\\" ] && ARGS=\\\"$ARGS --file $PRD_FILE\\\"\\n            [ -n \\\"$ISSUE_NUMBER\\\" ] && ARGS=\\\"$ARGS --issue-number $ISSUE_NUMBER\\\"\\n            [ -n \\\"$TASK_ID\\\" ] && ARGS=\\\"$ARGS --task-id $TASK_ID\\\"\\n            kody-engine taskify $ARGS\\n          else\\n            CMD=\\\"run\\\"\\n            [ \\\"$MODE\\\" = \\\"rerun\\\" ] && CMD=\\\"rerun\\\"\\n            [ \\\"$MODE\\\" = \\\"fix\\\" ] && CMD=\\\"fix\\\"\\n            [ \\\"$MODE\\\" = \\\"fix-ci\\\" ] && CMD=\\\"fix-ci\\\"\\n            [ \\\"$MODE\\\" = \\\"review\\\" ] && CMD=\\\"review\\\"\\n            [ \\\"$MODE\\\" = \\\"resolve\\\" ] && CMD=\\\"resolve\\\"\\n            [ \\\"$MODE\\\" = \\\"status\\\" ] && CMD=\\\"status\\\"\\n            [ \\\"$MODE\\\" = \\\"hotfix\\\" ] && CMD=\\\"hotfix\\\"\\n            ARGS=\\\"--issue-number $ISSUE_NUMBER\\\"\\n            [ -n \\\"$TASK_ID\\\" ] && ARGS=\\\"$ARGS --task-id $TASK_ID\\\"\\n            [ -n \\\"$PR_NUMBER\\\" ] && ARGS=\\\"$ARGS --pr-number $PR_NUMBER\\\"\\n            [ -n \\\"$FROM_STAGE\\\" ] && ARGS=\\\"$ARGS --from $FROM_STAGE\\\"\\n            [ -n \\\"$COMPLEXITY\\\" ] && ARGS=\\\"$ARGS --complexity $COMPLEXITY\\\"\\n            # FEEDBACK is also passed via env var (avoids shell escaping issues)\\n            [ -n \\\"$FEEDBACK\\\" ] && ARGS=\\\"$ARGS --feedback \\\\\\\"$FEEDBACK\\\\\\\"\\\"\\n            [ \\\"$DRY_RUN\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --dry-run\\\"\\n            [ \\\"$AUTO_MODE\\\" = \\\"true\\\" ] && ARGS=\\\"$ARGS --auto-mode\\\"\\n            kody-engine $CMD $ARGS\\n          fi\\n\\n      - name: Pipeline summary\\n        if: always()\\n        run: |\\n          TASK_ID=\\\"${{ github.event.inputs.task_id || needs.parse.outputs.task_id }}\\\"\\n          STATUS_FILE=\\\".kody/tasks/${TASK_ID}/status.json\\\"\\n          if [ -f \\\"$STATUS_FILE\\\" ]; then\\n            STATE=$(jq -r '.state' \\\"$STATUS_FILE\\\")\\n            ICON=\\\"❌\\\"\\n            [ \\\"$STATE\\\" = \\\"completed\\\" ] && ICON=\\\"✅\\\"\\n            echo \\\"## ${ICON} Kody Pipeline: \\\\`${TASK_ID}\\\\`\\\" >> $GITHUB_STEP_SUMMARY\\n            echo \\\"\\\" >> $GITHUB_STEP_SUMMARY\\n            echo \\\"**Status:** ${STATE}\\\" >> $GITHUB_STEP_SUMMARY\\n            echo \\\"\\\" >> $GITHUB_STEP_SUMMARY\\n            echo \\\"| Stage | State |\\\" >> $GITHUB_STEP_SUMMARY\\n            echo \\\"|-------|-------|\\\" >> $GITHUB_STEP_SUMMARY\\n            for stage in taskify plan build verify review review-fix ship; do\\n              SSTATE=$(jq -r \\\".stages[\\\\\\\"$stage\\\\\\\"].state // \\\\\\\"—\\\\\\\"\\\" \\\"$STATUS_FILE\\\")\\n              case \\\"$SSTATE\\\" in\\n                completed) SICON=\\\"✅\\\" ;;\\n                failed)    SICON=\\\"❌\\\" ;;\\n                timeout)   SICON=\\\"⏱\\\" ;;\\n                running)   SICON=\\\"▶️\\\" ;;\\n                *)         SICON=\\\"○\\\" ;;\\n              esac\\n              echo \\\"| ${stage} | ${SICON} ${SSTATE} |\\\" >> $GITHUB_STEP_SUMMARY\\n            done\\n          fi\\n\\n      - name: Upload artifacts\\n        if: always()\\n        uses: actions/upload-artifact@v4\\n        continue-on-error: true\\n        with:\\n          name: kody-tasks-${{ github.event.inputs.task_id || needs.parse.outputs.task_id }}\\n          path: .kody/tasks/\\n          retention-days: 3\\n\\n  # ─── Close Issue on PR Merge ────────────────────────────────────────────────\\n  close-issue-on-merge:\\n    if: >-\\n      github.event_name == 'pull_request' &&\\n      github.event.pull_request.merged == true\\n    runs-on: ubuntu-latest\\n    permissions:\\n      issues: write\\n    steps:\\n      - name: Generate App token\\n        id: app-token\\n        if: vars.KODY_APP_ID != ''\\n        uses: actions/create-github-app-token@v1\\n        with:\\n          app-id: ${{ vars.KODY_APP_ID }}\\n          private-key: ${{ secrets.APP_PRIVATE_KEY }}\\n          repositories: ${{ github.event.repository.name }}\\n\\n      - name: Close linked issue\\n        uses: actions/github-script@v7\\n        with:\\n          github-token: ${{ steps.app-token.outputs.token || secrets.GITHUB_TOKEN }}\\n          script: |\\n            // Extract issue number from branch name (e.g. \\\"42-feature-name\\\")\\n            const branch = context.payload.pull_request.head.ref;\\n            const match = branch.match(/^(\\\\d+)-/);\\n            if (!match) return;\\n            const issueNumber = parseInt(match[1], 10);\\n\\n            // Verify the issue exists and is open\\n            try {\\n              const { data: issue } = await github.rest.issues.get({\\n                owner: context.repo.owner,\\n                repo: context.repo.repo,\\n                issue_number: issueNumber,\\n              });\\n              if (issue.state === 'closed') return;\\n              if (issue.pull_request) return; // Skip if it's a PR, not an issue\\n\\n              await github.rest.issues.update({\\n                owner: context.repo.owner,\\n                repo: context.repo.repo,\\n                issue_number: issueNumber,\\n                state: 'closed',\\n                state_reason: 'completed',\\n              });\\n              core.info(`Closed issue #${issueNumber} after PR #${context.payload.pull_request.number} was merged`);\\n            } catch (e) {\\n              core.warning(`Could not close issue #${issueNumber}: ${e.message}`);\\n            }\\n\\n  # ─── Error Notifications ─────────────────────────────────────────────────────\\n  notify-parse-error:\\n    if: >-\\n      github.event_name == 'issue_comment' &&\\n      needs.parse.outputs.valid != 'true' &&\\n      (contains(github.event.comment.body, '@kody') || contains(github.event.comment.body, '/kody'))\\n    needs: [parse]\\n    runs-on: ubuntu-latest\\n    steps:\\n      - uses: actions/github-script@v7\\n        with:\\n          script: |\\n            await github.rest.issues.createComment({\\n              owner: context.repo.owner,\\n              repo: context.repo.repo,\\n              issue_number: context.issue.number,\\n              body: '❌ Failed to parse command.\\\\n\\\\nUsage: `@kody [full|rerun|fix|fix-ci|review|resolve|status] [--from <stage>] [--feedback \\\"<text>\\\"]`'\\n            })\\n\\n  notify-orchestrate-error:\\n    if: failure() && needs.orchestrate.result == 'failure'\\n    needs: [orchestrate]\\n    runs-on: ubuntu-latest\\n    steps:\\n      - uses: actions/github-script@v7\\n        with:\\n          script: |\\n            const issueNumber = Number('${{ github.event.inputs.issue_number || needs.parse.outputs.issue_number || 0 }}');\\n            if (issueNumber > 0) {\\n              await github.rest.issues.createComment({\\n                owner: context.repo.owner,\\n                repo: context.repo.repo,\\n                issue_number: issueNumber,\\n                body: `❌ Pipeline failed. [View logs](${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId})`\\n              });\\n            }\\n\\n  # ─── Fix-CI Auto-trigger (workflow_run trigger) ─────────────────────────────\\n  fix-ci-trigger:\\n    if: >-\\n      github.event_name == 'workflow_run' &&\\n      github.event.workflow_run.conclusion == 'failure' &&\\n      github.event.workflow_run.event == 'pull_request' &&\\n      github.event.workflow_run.pull_requests[0]\\n    runs-on: ubuntu-latest\\n    timeout-minutes: 5\\n    permissions:\\n      issues: write\\n      pull-requests: write\\n    steps:\\n      - name: Check loop guard and post fix-ci comment\\n        uses: actions/github-script@v7\\n        with:\\n          script: |\\n            const pr = context.payload.workflow_run.pull_requests[0];\\n            const prNumber = pr.number;\\n\\n            // Check recent comments for existing fix-ci attempt (last 24h)\\n            const comments = await github.rest.issues.listComments({\\n              owner: context.repo.owner,\\n              repo: context.repo.repo,\\n              issue_number: prNumber,\\n              per_page: 30,\\n            });\\n\\n            const oneDayAgo = new Date(Date.now() - 24 * 60 * 60 * 1000);\\n            const recentFixCi = comments.data.filter(\\n              (c) => c.body.includes('@kody fix-ci') && new Date(c.created_at) > oneDayAgo\\n            );\\n\\n            if (recentFixCi.length >= 1) {\\n              core.info('Loop guard: @kody fix-ci already commented in last 24h, skipping');\\n              return;\\n            }\\n\\n            // Check if last commit was from a bot (kody's previous fix attempt)\\n            const commits = await github.rest.pulls.listCommits({\\n              owner: context.repo.owner,\\n              repo: context.repo.repo,\\n              pull_number: prNumber,\\n              per_page: 1,\\n            });\\n            const lastAuthor = commits.data[commits.data.length - 1]?.commit?.author?.name;\\n            if (lastAuthor === 'github-actions[bot]' || lastAuthor === 'kody[bot]') {\\n              core.info('Loop guard: last commit from bot, skipping');\\n              return;\\n            }\\n\\n            // Post fix-ci comment\\n            const runId = context.payload.workflow_run.id;\\n            const runUrl = `${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${runId}`;\\n            await github.rest.issues.createComment({\\n              owner: context.repo.owner,\\n              repo: context.repo.repo,\\n              issue_number: prNumber,\\n              body: `@kody fix-ci\\\\nCI failed: [View logs](${runUrl})\\\\nRun ID: ${runId}`,\\n            });\\n            core.info(`Posted @kody fix-ci on PR #${prNumber} for run ${runId}`);\\n=======\\n      - uses: actions/setup-python@v5\\n        with:\\n          python-version: '3.12'\\n          cache: 'pip'\\n          cache-dependency-path: .kody-pip-requirements.txt\\n\\n      # Pre-pull the MongoDB image used by scripts/release-e2e-gate.ts\\n      # (invoked during `@kody release --finalize`). The pull happens in its\\n      # own GitHub Actions step, outside kody's internal per-step timeout,\\n      # so the gate starts with the image already in the local Docker cache.\\n      - name: Warm Docker image cache for release e2e gate\\n        run: docker pull mongo:6\\n\\n      - env:\\n          ALL_SECRETS: ${{ toJSON(secrets) }}\\n          SESSION_ID: ${{ inputs.sessionId }}\\n          INIT_MESSAGE: ${{ inputs.message }}\\n          MODEL: ${{ inputs.model }}\\n          DASHBOARD_URL: ${{ inputs.dashboardUrl }}\\n        run: npx -y -p @kody-ade/kody-engine@latest kody\\n>>>>>>> origin/dev\\n\",\"numLines\":574,\"startLine\":1,\"totalLines\":574}}}\n{\"type\":\"assistant\",\"message\":{\"id\":\"0641370a8b36ba0a68d1c68bee176bb6\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"call_function_k31217mj7xo0_2\",\"name\":\"Read\",\"input\":{\"file_path\":\"/home/runner/work/A-Guy/A-Guy/.kody/last-run.jsonl\"}}],\"model\":\"MiniMax-M2.7-highspeed\",\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":142,\"output_tokens\":0,\"cache_creation_input_tokens\":21515,\"cache_read_input_tokens\":19997},\"service_tier\":\"standard\",\"context_management\":null},\"parent_tool_use_id\":null,\"session_id\":\"01102eb0-252a-47dc-9009-d0d0ba855c49\",\"uuid\":\"b9bc7f7f-eb05-45d2-be79-09f0275772ea\"}\n","numLines":6,"startLine":1,"totalLines":6}}}
