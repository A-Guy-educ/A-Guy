   \"AI_BASE_URL\",\n      \"AI_KEY\",\n      \"AI_MODEL\",\n      \"BLOB_READ_WRITE_TOKEN\",\n      \"BRAIN_AUTH_KEY\",\n      \"CRON_SECRET\",\n      \"DATABASE_URL\",\n      \"DATABASE_URL_ATLAS\",\n      \"FIGMA_API_KEY\",\n      \"GEMINI_API_KEY\",\n      \"GROQ_API_KEY\",\n      \"MINIMAX_API_KEY\",\n      \"NEXT_PUBLIC_SERVER_URL\",\n      \"OPENAI_API_KEY\",\n      \"PAYLOAD_SECRET\",\n      \"SLACK_WEBHOOK_URL\",\n      \"SLACK_WEBHOOK_URL_DEV\"\n    ]\n=======\n>>>>>>> origin/dev\n  }\n}\n","numLines":88,"startLine":1,"totalLines":88}}}
