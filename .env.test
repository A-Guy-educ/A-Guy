# Test environment configuration
# This file is loaded by playwright.config.ts and overrides .env values

# DATABASE_URL=
# Leave empty for testcontainers (recommended for local dev)
# Testcontainers will auto-populate this at runtime
DEFAULT_TENANT_SLUG=default

# Suppress pino logger output during tests
LOG_LEVEL=silent

# Dummy token for tests — satisfies the required-check in plugins/index.ts
# Actual blob API calls are mocked in tests that need them
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_testStoreId1234_testRandomStringForIntegrationTests
