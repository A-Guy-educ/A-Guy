{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm typecheck",
    "lint": "pnpm lint",
    "format": "pnpm format",
    "testUnit": "pnpm test:unit:coverage"
  },
  "git": {
    "defaultBranch": "dev"
  },
  "github": {
    "owner": "A-Guy-educ",
    "repo": "A-Guy"
  },
  "agent": {
    "model": "minimax/MiniMax-M2.7-highspeed",
    "modelMap": {
      "cheap": "minimax/MiniMax-M2.7-highspeed",
      "mid": "minimax/MiniMax-M2.7-highspeed",
      "strong": "minimax/MiniMax-M2.7-highspeed"
    },
    "budgets": {
      "taskify": { "maxTurns": 300, "maxBudgetUsd": 15.0 },
      "plan": { "maxTurns": 300, "maxBudgetUsd": 10.0 },
      "build": { "maxTurns": 1000, "maxBudgetUsd": 50.0 },
      "verify": { "maxTurns": 200, "maxBudgetUsd": 5.0 },
      "review": { "maxTurns": 300, "maxBudgetUsd": 10.0 },
      "review-fix": { "maxTurns": 600, "maxBudgetUsd": 30.0 },
      "ship": { "maxTurns": 200, "maxBudgetUsd": 5.0 }
    }
  },
  "release": {
    "releaseBranch": "main",
    "versionFiles": ["package.json"],
    "notifyCommand": "NOTIFY_RESULT=always NOTIFY_VERSION=$VERSION pnpm tsx scripts/kody/notify.ts --agent release-publisher --channels slack --when always --color good --title \"🚀 A-Guy v$VERSION released\" --body \"Release $VERSION finalized — https://github.com/A-Guy-educ/A-Guy/releases/tag/v$VERSION\"",
    "e2eCommand": "npx tsx scripts/release-e2e-gate.ts",
    "timeoutMs": 1800000
  },
  "watch": {
    "enabled": true,
    "digestIssue": null,
    "model": "minimax/MiniMax-M2.7-highspeed",
    "provider": "minimax"
  },
  "timeouts": {
    "taskify": 18000,
    "plan": 18000,
    "build": 72000,
    "verify": 9000,
    "review": 18000,
    "review-fix": 36000,
    "ship": 7200
  },
  "devServer": {
    "command": "pnpm dev",
    "url": "http://localhost:3000",
    "readyPattern": "Ready in|compiled|started server|Local:|localhost:|✓ Ready",
    "readyTimeout": 180,
    "env": [
      "AI_BASE_URL",
      "AI_KEY",
      "AI_MODEL",
      "BLOB_READ_WRITE_TOKEN",
      "BRAIN_AUTH_KEY",
      "CRON_SECRET",
      "DATABASE_URL",
      "DATABASE_URL_ATLAS",
      "FIGMA_API_KEY",
      "GEMINI_API_KEY",
      "GROQ_API_KEY",
      "MINIMAX_API_KEY",
      "NEXT_PUBLIC_SERVER_URL",
      "OPENAI_API_KEY",
      "PAYLOAD_SECRET",
      "SLACK_WEBHOOK_URL",
      "SLACK_WEBHOOK_URL_DEV"
    ]
  },
  "missions": {
    "stateBackend": "local-file"
  }
}
